Функция ПолучитьТаблицуФайловСервисныхРабот(ПараметрыЗапроса) Экспорт
	
	СписокДокументов = Новый Массив;
	СписокФайлов = Новый Массив; 
	
	Если ОбщегоНазначенияКлиентСервер.ЕстьРеквизитИлиСвойствоОбъекта(ПараметрыЗапроса, "СписокДокументов") Тогда
		Для Каждого ДанныеДокумента Из ПараметрыЗапроса.СписокДокументов Цикл
			ГУИДДокумента = ДанныеДокумента.GUID;                                                  
			СтруктураПоиска = Неопределено;
			Если ОбщегоНазначенияКлиентСервер.ЕстьРеквизитИлиСвойствоОбъекта(ДанныеДокумента, "Дата") 
				И ЗначениеЗаполнено(ДанныеДокумента.Дата) Тогда
				СтруктураПоиска = Новый Структура("Дата", XMLЗначение(Тип("Дата"), ДанныеДокумента.Дата));
			КонецЕсли;
			Если ОбщегоНазначенияКлиентСервер.ЕстьРеквизитИлиСвойствоОбъекта(ДанныеДокумента, "Номер") 
				И ЗначениеЗаполнено(ДанныеДокумента.Номер) Тогда
				Если СтруктураПоиска = Неопределено Тогда
					СтруктураПоиска = Новый Структура("Номер", ДанныеДокумента.Номер);
				Иначе
					СтруктураПоиска.Вставить("Номер", ДанныеДокумента.Номер);
				КонецЕсли;
			КонецЕсли;   
			
			Если ОбщегоНазначенияКлиентСервер.ЕстьРеквизитИлиСвойствоОбъекта(ДанныеДокумента, "ДокументОснование") Тогда    
				ГУИДОснования = ПустойИдентификатор;
				ПоискОснования = Новый Структура;
				Если ОбщегоНазначенияКлиентСервер.ЕстьРеквизитИлиСвойствоОбъекта(ДанныеДокумента.ДокументОснование, "GUID") Тогда
					ГУИДОснования = ДанныеДокумента.ДокументОснование.GUID;
				КонецЕсли;
				Если ОбщегоНазначенияКлиентСервер.ЕстьРеквизитИлиСвойствоОбъекта(ДанныеДокумента.ДокументОснование, "Дата") 
					И ЗначениеЗаполнено(XMLЗначение(Тип("Дата"), ДанныеДокумента.ДокументОснование.Дата)) Тогда
					ПоискОснования.Вставить("Дата", XMLЗначение(Тип("Дата"), ДанныеДокумента.ДокументОснование.Дата));
				КонецЕсли;
				Если ОбщегоНазначенияКлиентСервер.ЕстьРеквизитИлиСвойствоОбъекта(ДанныеДокумента.ДокументОснование, "Номер") 
					И ЗначениеЗаполнено(ДанныеДокумента.ДокументОснование.Номер) Тогда
					ПоискОснования.Вставить("Номер", ДанныеДокумента.ДокументОснование.Номер);
				КонецЕсли;
				Если ОбщегоНазначенияКлиентСервер.ЕстьРеквизитИлиСвойствоОбъекта(ДанныеДокумента.ДокументОснование, "Код") 
					И ЗначениеЗаполнено(ДанныеДокумента.ДокументОснование.Код) Тогда
					ПоискОснования.Вставить("Код", ДанныеДокумента.ДокументОснование.Код);
				КонецЕсли;
				Если ОбщегоНазначенияКлиентСервер.ЕстьРеквизитИлиСвойствоОбъекта(ДанныеДокумента.ДокументОснование, "ДатаРегистрации") 
					И ЗначениеЗаполнено(ДанныеДокумента.ДокументОснование.ДатаРегистрации) Тогда
					ПоискОснования.Вставить("ДатаРегистрации", XMLЗначение(Тип("Дата"), ДанныеДокумента.ДокументОснование.ДатаРегистрации));
				КонецЕсли;
				Если ОбщегоНазначенияКлиентСервер.ЕстьРеквизитИлиСвойствоОбъекта(ДанныеДокумента.ДокументОснование, "ТипЗначения") Тогда
					ТипОснования = ДанныеДокумента.ДокументОснование.ТипЗначения;
				КонецЕсли;                       
				
				ДокументОснование = Неопределено;
				
				Если ГУИДОснования <> ПустойИдентификатор Или ЗначениеЗаполнено(ТипОснования) Тогда 
					Если СтрНайти(ТипОснования, "Справочник.") = 1 Тогда                                              
						ТипСправочника = СтрЗаменить(ТипОснования, "Справочник.",""); 
						ДокументОснованиеОбъект = ПолучитьОбъектОбработкиСправочник(ТипСправочника, ГУИДОснования, ПоискОснования, Ложь);
