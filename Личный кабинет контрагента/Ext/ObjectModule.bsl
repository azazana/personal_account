Функция ПолучитьТаблицуРаботыИнженера(ПараметрыЗапроса) Экспорт
	
	СписокРабот = Новый Массив;
	Если ОбщегоНазначенияКлиентСервер.ЕстьРеквизитИлиСвойствоОбъекта(ПараметрыЗапроса, "СписокРабот") Тогда
		Для Каждого ДанныеРаботы Из ПараметрыЗапроса.СписокРабот Цикл
			ГУИДРаботы = ДанныеРаботы.GUID;                                                  
			СтруктураПоиска = Новый Структура;
			Если ОбщегоНазначенияКлиентСервер.ЕстьРеквизитИлиСвойствоОбъекта(ДанныеРаботы, "Код") Тогда
				СтруктураПоиска.Вставить("Код", ДанныеРаботы.Код);
			КонецЕсли;
			РаботаИнженераОбъект = ПолучитьОбъектОбработкиСправочник("КАМИ_РаботыИнженера", ГУИДРаботы, СтруктураПоиска, Ложь);
			Если НЕ РаботаИнженераОбъект.ЭтоНовый() Тогда
				СписокРабот.Добавить(РаботаИнженераОбъект.Ссылка);
			КонецЕсли;
		КонецЦикла;
	КонецЕсли;

	Если ОбщегоНазначенияКлиентСервер.ЕстьРеквизитИлиСвойствоОбъекта(ПараметрыЗапроса, "СписокСсылок") Тогда
		Для Каждого ДанныеСсылки Из ПараметрыЗапроса.СписокСсылок Цикл		
			СписокРабот.Добавить(ДанныеСсылки);
		КонецЦикла;
	КонецЕсли;

	Если СписокРабот.Количество() = 0 Тогда		
		СписокРабот.Добавить(Справочники.КАМИ_РаботыИнженера.ПустаяСсылка()); 
	КонецЕсли;  
	
	мОбъектЗапроса = Новый Запрос;
	мОбъектЗапроса.Текст = ТекстЗапросаРаботыИнженера();	
	мОбъектЗапроса.УстановитьПараметр("СписокРабот", СписокРабот);
	
	ТаблицаРезультат = мОбъектЗапроса.Выполнить().Выгрузить();      

	ЗаполнитьКэшСсылокПоТаблицеЗначений(ТаблицаРезультат);

	Возврат ТаблицаРезультат;
	
КонецФункции

Функция ПолучитьТаблицуДолжностиИнженеров(ПараметрыЗапроса) Экспорт
	
	СписокПользователей = Новый Массив;

	Если ОбщегоНазначенияКлиентСервер.ЕстьРеквизитИлиСвойствоОбъекта(ПараметрыЗапроса, "СписокПользователей") Тогда
		Для Каждого ДанныеПользователя Из ПараметрыЗапроса.СписокПользователей Цикл
			ГУИДПользователя = ДанныеПользователя.GUID;
			Если ЗначениеЗаполнено(ГУИДПользователя)
				И НЕ ГУИДПользователя = ПустойИдентификатор Тогда
				ПользовательИД = Новый УникальныйИдентификатор(ГУИДПользователя);
				СписокПользователей.Добавить(ПользовательИД);
			КонецЕсли;
		КонецЦикла;
	КонецЕсли;

	СписокИнженеров = Новый Массив;

	Если ОбщегоНазначенияКлиентСервер.ЕстьРеквизитИлиСвойствоОбъекта(ПараметрыЗапроса, "СписокИнженеров") Тогда
		Для Каждого ДанныеИнженера Из ПараметрыЗапроса.СписокИнженеров Цикл                                                
			
			Если НЕ ОбщегоНазначенияКлиентСервер.ЕстьРеквизитИлиСвойствоОбъекта(ДанныеИнженера, "Код") Тогда 
				Продолжить;
			КонецЕсли;     
			
			СтруктураПоиска = Новый Структура;
			СтруктураПоиска.Вставить("Код", ДанныеИнженера.Код);
			ИнженерОбъект = ПолучитьОбъектОбработкиСправочник("ФизическиеЛица", ПустойИдентификатор, СтруктураПоиска, Ложь);
			Если НЕ ИнженерОбъект.ЭтоНовый() Тогда
				СписокИнженеров.Добавить(ИнженерОбъект.Ссылка);
			КонецЕсли;
		КонецЦикла;
	КонецЕсли;
	
	мОбъектЗапроса = Новый Запрос;
	мОбъектЗапроса.Текст = ТекстЗапросаДолжностиИнженеров();
	
	мОбъектЗапроса.УстановитьПараметр("СписокПользователей", СписокПользователей);
