Функция СоздатьЗаявкуНаРасходДС_ПоСервиснымРаботам(тСтруктураПараметров)
	
	Ответ = Новый Структура;
	
	Если НЕ ОбщегоНазначенияКлиентСервер.ЕстьРеквизитИлиСвойствоОбъекта(тСтруктураПараметров, "ГУИД_СервисныхРабот") Тогда 
		
		РезультатЗапроса = "Документы не созданы";     
		Ответ.Вставить("РезультатЗапроса", РезультатЗапроса);
		Ответ.Вставить("ТекстОшибки","Нет ГУИД сервисных работ");
		Ответ.Вставить("СтатусОтвета",400);
		
		Возврат Ответ;
		
	КонецЕсли;
	
	УИД_СервисныхРабот = новый УникальныйИдентификатор(тСтруктураПараметров.ГУИД_СервисныхРабот);
	докСервисныеРаботы = Документы.КАМИ_СервисныеРаботы.ПолучитьСсылку(УИД_СервисныхРабот);
	Если НЕ ЗначениеЗаполнено(докСервисныеРаботы) Тогда 
		
		РезультатЗапроса = "Документы не созданы";     
		Ответ.Вставить("РезультатЗапроса", РезультатЗапроса);
		Ответ.Вставить("ТекстОшибки","Нет документа Сервисные работы с данным ГУИД");
		Ответ.Вставить("СтатусОтвета",400);
		
		Возврат Ответ;
		
	КонецЕсли; 
	
	Если ОбщегоНазначенияКлиентСервер.ЕстьРеквизитИлиСвойствоОбъекта(тСтруктураПараметров, "ГУИД_Инженера") Тогда 
		УИД_Инженера = новый УникальныйИдентификатор(тСтруктураПараметров.ГУИД_Инженера); 
		тПользовательОС = ПользователиИнформационнойБазы.НайтиПоУникальномуИдентификатору(УИД_Инженера);	
		тПользователь = справочники.Пользователи.НайтиПоНаименованию(тПользовательОС.Имя);
		тИнженер = тПользователь.ФизическоеЛицо;
	Иначе
		тИнженер = справочники.ФизическиеЛица.ПустаяСсылка();	
	КонецЕсли; 
	
	найдКомандировка = найтиКомандировкуПоСервиснымРаботам(докСервисныеРаботы, тИнженер);
	Если НЕ ЗначениеЗаполнено(найдКомандировка) Тогда 
		
		РезультатЗапроса = "Документы не созданы";     
		Ответ.Вставить("РезультатЗапроса", РезультатЗапроса);
		
		Если ОбщегоНазначенияКлиентСервер.ЕстьРеквизитИлиСвойствоОбъекта(тСтруктураПараметров, "ГУИД_Инженера") Тогда
			Ответ.Вставить("ТекстОшибки","Нет командировки созданной на основе Сервисных работ с данным ГУИД для сотрудника с переданным ГУИД сотрудника"); 
		Иначе	
			Ответ.Вставить("ТекстОшибки","Нет командировки созданной на основе Сервисных работ с данным ГУИД"); 
		КонецЕсли; 
		
		Ответ.Вставить("СтатусОтвета",400);
		
		Возврат Ответ;
		
	КонецЕсли;       
	
	Если ОбщегоНазначенияКлиентСервер.ЕстьРеквизитИлиСвойствоОбъекта(тСтруктураПараметров, "СуммаДокумента") Тогда 
		тСуммаЗаявки = Число(тСтруктураПараметров.СуммаДокумента);
	Иначе
		тСуммаЗаявки = найдКомандировка.СуммаДокумента;
	КонецЕсли;       
	
	ЗаявкаНаРасходДС = СоздатьЗаявкуНаРасходДС(найдКомандировка, тСуммаЗаявки);	
	
	Если ЗначениеЗаполнено(ЗаявкаНаРасходДС) Тогда 
		
		ТаблицаРезультат = Новый ТаблицаЗначений;
		ТаблицаРезультат.Колонки.Добавить("Ссылка");
		НоваяСтрочка = ТаблицаРезультат.Добавить();
		НоваяСтрочка.Ссылка = ЗаявкаНаРасходДС;      
		
		ЗаполнитьКэшСсылокПоТаблицеЗначений(ТаблицаРезультат);
		
		РезультатЗапроса = ЗаполнитьТаблицуЗначенийПоКэшуСсылок(ТаблицаРезультат);
		
		Ответ = Новый Структура;
		
		Ответ.Вставить("РезультатЗапроса", РезультатЗапроса);
		Ответ.Вставить("ТекстОшибки","");
		Ответ.Вставить("СтатусОтвета",200);
		
		Возврат Ответ;
	Иначе    
		РезультатЗапроса = "Документы не созданы";     
		Ответ.Вставить("РезультатЗапроса", РезультатЗапроса);                                                               
		Если ОбщегоНазначенияКлиентСервер.ЕстьРеквизитИлиСвойствоОбъекта(тСтруктураПараметров, "ГУИД_Инженера") Тогда 
			Ответ.Вставить("ТекстОшибки","Внутренняя ошибка 1С. Не удалось создать заявку на расход ДС по найденной командировке найденному пользователю на заданную сумму");  
		Иначе
			Ответ.Вставить("ТекстОшибки","Внутренняя ошибка 1С. Не удалось создать заявку на расход ДС по найденной командировке на заданную сумму");  
		КонецЕсли;       
		Ответ.Вставить("СтатусОтвета",400);
		
		Возврат Ответ;
		
	КонецЕсли;       
	
КонецФункции                                 


Функция найтиКомандировкуПоСервиснымРаботам(тСервисныеРаботы, текИнженер)

	Запрос = новый Запрос;

	Если ЗначениеЗаполнено(текИнженер) Тогда
		Запрос.Текст = "ВЫБРАТЬ
		               |	ЗаявкаНаКомандировку.Ссылка КАК Ссылка
		               |ИЗ
		               |	Документ.ЗаявкаНаКомандировку КАК ЗаявкаНаКомандировку
		               |ГДЕ
		               |	НЕ ЗаявкаНаКомандировку.ПометкаУдаления
		               |	И ЗаявкаНаКомандировку.КАМИ_ДокументОснование = &КАМИ_ДокументОснование
		               |	И ЗаявкаНаКомандировку.Сотрудник = &Сотрудник"; 
		
		Запрос.УстановитьПараметр("Сотрудник", текИнженер);
	Иначе	
		Запрос.Текст = "ВЫБРАТЬ
		               |	ЗаявкаНаКомандировку.Ссылка КАК Ссылка
		               |ИЗ
		               |	Документ.ЗаявкаНаКомандировку КАК ЗаявкаНаКомандировку
		               |ГДЕ
		               |	НЕ ЗаявкаНаКомандировку.ПометкаУдаления
		               |	И ЗаявкаНаКомандировку.КАМИ_ДокументОснование = &КАМИ_ДокументОснование";    
	КонецЕсли;
	
	Запрос.УстановитьПараметр("КАМИ_ДокументОснование", тСервисныеРаботы);
	РезЗапроса = Запрос.Выполнить();
	Если РезЗапроса.Пустой() Тогда
		Возврат неопределено;	
	Иначе	
		Выборка = РезЗапроса.Выбрать();
		Выборка.Следующий();
		Возврат Выборка.Ссылка; 
	КонецЕсли;	
	
КонецФункции
