#Область ОбработкиРеквизитов

Функция ПолучитьСтруктуруПоСсылке(СсылкаНаРеквизит) 
	
	Если НЕ ЗначениеЗаполнено(СсылкаНаРеквизит) Тогда
		Возврат "";
	КонецЕсли;
	Если КэшСсылок = Неопределено Тогда
		КэшСсылок = Новый Соответствие;
	КонецЕсли;
	
	Результат = КэшСсылок[СсылкаНаРеквизит];
	Если Результат <> Неопределено Тогда
		Возврат Результат;
	КонецЕсли;
	
	МассивСсылок = Новый Массив;
	МассивСсылок.Добавить(СсылкаНаРеквизит);
	Результат = ПолучитьРеквизитыПоМассивуСсылок(МассивСсылок)[СсылкаНаРеквизит];
	Если Результат <> Неопределено Тогда
		Возврат Результат;
	КонецЕсли;
	
	Возврат "";
	
КонецФункции

Функция ЗаполнитьТаблицуЗначенийПоКэшуСсылок(ТаблицаРезультат)
	
	Если КэшСсылок = Неопределено Тогда
		КэшСсылок = Новый Соответствие;
	КонецЕсли;
	
	ОписаниеПолей = ПолучитьОписанияКолонокСтруктурой(ТаблицаРезультат.Колонки);
	ВыборкаДанных = ОбщегоНазначения.ТаблицаЗначенийВМассив(ТаблицаРезультат);
	СтатистикаТипов = Новый Соответствие;
	Результат = Новый Массив; 
	НомерСтроки = 0;
	Для Каждого СтрочкаТаблицы Из ВыборкаДанных Цикл
		СтруктураСтроки = Новый Структура;
		НомерСтроки = НомерСтроки + 1;
		Для Каждого РеквизитСтроки Из СтрочкаТаблицы Цикл
			НовоеЗначение = КэшСсылок.Получить(РеквизитСтроки.Значение);
			Если НовоеЗначение = Неопределено Тогда
				НовоеЗначение = РеквизитСтроки.Значение;
			КонецЕсли;  
			
			Если ТипЗнч(НовоеЗначение) = Тип("УникальныйИдентификатор") Тогда
				НовоеЗначение = XMLСтрока(НовоеЗначение);
			КонецЕсли;
			
			НовоеЗначение = ?(ЗначениеЗаполнено(НовоеЗначение), НовоеЗначение, "");
			
			КоличествоСсылок = СтатистикаТипов.Получить(ТипЗнч(?(ЗначениеЗаполнено(РеквизитСтроки.Значение),РеквизитСтроки.Значение,"")));
			КоличествоСсылок = ?(КоличествоСсылок = Неопределено, 0, КоличествоСсылок) + 1;
			СтатистикаТипов.Вставить(ТипЗнч(?(ЗначениеЗаполнено(РеквизитСтроки.Значение),РеквизитСтроки.Значение,"")), КоличествоСсылок);
			СтруктураСтроки.Вставить(РеквизитСтроки.Ключ, НовоеЗначение);
		КонецЦикла;
		Попытка
			СтрокаДляОтвета = УпаковатьОтветВJSON(СтруктураСтроки);
		Исключение    
			ПолноеОписаниеОшибки = "Строка " + Формат(НомерСтроки, "ЧГ=0") + " :" + ПодробноеПредставлениеОшибки(ИнформацияОбОшибке()); 
			#Если Сервер Или ТолстыйКлиентОбычноеПриложение Тогда  
				Сообщить(ПолноеОписаниеОшибки);
			#КонецЕсли			
			Продолжить;
		КонецПопытки;
		Результат.Добавить(СтруктураСтроки);
	КонецЦикла;
	
	СтруктураРезультата = Новый Структура;
	СтруктураРезультата.Вставить("ОписаниеПолей", ОписаниеПолей);
	СтруктураРезультата.Вставить("Результат", Результат);
	
	Возврат СтруктураРезультата;
	
КонецФункции

Процедура ЗаполнитьКэшСсылокПоТаблицеЗначений(ТаблицаРезультат)
	
	ТаблицаСсылок = Новый ТаблицаЗначений;
	ТаблицаСсылок.Колонки.Добавить("Ссылка");
	Для Каждого Колонка Из ТаблицаРезультат.Колонки Цикл
		ЗначенияКолонки = ТаблицаРезультат.Скопировать(,Колонка.Имя);
		ЗначенияКолонки.Свернуть(Колонка.Имя);
		ЗначенияКолонки = ЗначенияКолонки.ВыгрузитьКолонку(Колонка.Имя);
		Для Каждого ЗначениеПоля Из ЗначенияКолонки Цикл
			НоваяСтрочка = ТаблицаСсылок.Добавить();
			НоваяСтрочка.Ссылка = ЗначениеПоля;
		КонецЦикла;
	КонецЦикла;
	ТаблицаСсылок.Свернуть("Ссылка");
	МассивСсылок = ТаблицаСсылок.ВыгрузитьКолонку("Ссылка");
	
	РеквизитыСсылок = ЗаполнитьКэшСсылокРекурсивно(МассивСсылок);
	
КонецПроцедуры

Функция ЗаполнитьКэшСсылокРекурсивно(МассивСсылок)
	НовыйМассивСсылок = Новый Массив;
	Для Каждого Строчка Из МассивСсылок Цикл
		Если ЭтоСсылка(ТипЗнч(Строчка)) Тогда
			НовыйМассивСсылок.Добавить(Строчка); 
		ИначеЕсли ТипЗнч(Строчка) = Тип("Массив") Тогда
			ЗаполнитьКэшСсылокРекурсивно(Строчка);
		ИначеЕсли ТипЗнч(Строчка) = Тип("Структура") Тогда
			МассивЗначений = Новый Массив; 
			Для Каждого СтрочкаЗначения Из Строчка Цикл
				МассивЗначений.Добавить(СтрочкаЗначения.Значение);
			КонецЦикла;
			ЗаполнитьКэшСсылокРекурсивно(МассивЗначений);
		ИначеЕсли ТипЗнч(Строчка) = Тип("Соответствие") Тогда
			МассивЗначений = Новый Массив; 
			Для Каждого СтрочкаЗначения Из Строчка Цикл
				МассивЗначений.Добавить(СтрочкаЗначения.Значение);
			КонецЦикла;
			ЗаполнитьКэшСсылокРекурсивно(МассивЗначений);
		КонецЕсли;
	КонецЦикла;
	
	Результат = ПолучитьРеквизитыПоМассивуСсылок(НовыйМассивСсылок);
	Если Ложь Тогда
		Результат = Новый Соответствие;
	КонецЕсли;
	
	Пока Результат.Количество() > 0 Цикл
		Для Каждого СтрочкаРезультата Из Результат Цикл
			КэшСсылок.Вставить(СтрочкаРезультата.Ключ, СтрочкаРезультата.Значение);
		КонецЦикла;
		НовыйМассивСсылок = Новый Массив;
		Для Каждого СтрочкаРезультата Из Результат Цикл
			Для Каждого Реквизит Из СтрочкаРезультата.Значение Цикл
				Если НЕ Реквизит.Ключ = "Ссылка" И ЭтоСсылка(ТипЗнч(Реквизит.Значение)) Тогда
					НовыйМассивСсылок.Добавить(Реквизит.Значение);
				КонецЕсли;
			КонецЦикла;
		КонецЦикла;
		Результат = ПолучитьРеквизитыПоМассивуСсылок(НовыйМассивСсылок);
	КонецЦикла;
	
	ПростыеСтруктуры = Новый Соответствие;
	
	Пока КэшСсылок.Количество()>0 Цикл
		Для Каждого СтрочкаКэша Из КэшСсылок Цикл
			СтруктураРеквизитов = СтрочкаКэша.Значение;
			НоваяСтруктура = Новый Структура;
			ПростаяСтруктура = Истина;
			Для Каждого Реквизит Из СтруктураРеквизитов Цикл  
				//+ КАМИ 19.07.2023 11:05:36 Гросу Р.И. № Реквизит объекта может быть ссылкой на сам объект (Пример ДокументОснование в СервисныеРаботы)
				Если СтрочкаКэша.Ключ = Реквизит.Значение И НЕ Реквизит.Ключ = "Ссылка" Тогда
					НовоеЗначение = XMLСтрока(Реквизит.Значение);	
				//- КАМИ 19.07.2023 11:05:38 Гросу Р.И. 
				ИначеЕсли НЕ Реквизит.Ключ = "Ссылка" Тогда   
					НовоеЗначение = ПростыеСтруктуры.Получить(Реквизит.Значение);
					Если НовоеЗначение = Неопределено Тогда
						НовоеЗначение = КэшСсылок.Получить(Реквизит.Значение);
						Если НовоеЗначение = Неопределено Тогда
							НовоеЗначение = Реквизит.Значение;
						Иначе
							ПростаяСтруктура = Ложь;Прервать;
						КонецЕсли;
					КонецЕсли; 
				Иначе
					НовоеЗначение = XMLСтрока(Реквизит.Значение);	
				КонецЕсли;
				НоваяСтруктура.Вставить(Реквизит.Ключ, НовоеЗначение);
			КонецЦикла;
			Если ПростаяСтруктура Тогда
				НоваяСтруктура.Вставить("Нпп", ПростыеСтруктуры.Количество() + 1);
				ПростыеСтруктуры.Вставить(СтрочкаКэша.Ключ, НоваяСтруктура);
				КэшСсылок.Удалить(СтрочкаКэша.Ключ);
			КонецЕсли;
		КонецЦикла;
	КонецЦикла;
	
	КэшСсылок = ПростыеСтруктуры;
	
КонецФункции

Функция ПолучитьРеквизитыПоМассивуСсылок(МассивСсылок) 
	
	Если КэшСсылок = Неопределено Тогда
		КэшСсылок = Новый Соответствие;
	КонецЕсли;
	Результат = Новый Соответствие;
	
	Если ТипЗнч(МассивСсылок) <> Тип("Массив") Тогда
		Возврат Результат;
	КонецЕсли;
	
	КэшТипов = Новый Соответствие;
	
	Для Каждого ЗначениеСсылки Из МассивСсылок Цикл
		ТипСсылки = ТипЗнч(ЗначениеСсылки);
		
		Если НЕ ЭтоСсылка(ТипСсылки) Тогда	
			Продолжить;
		КонецЕсли;
		
		Если КэшСсылок.Получить(ЗначениеСсылки) <> Неопределено Тогда
			Продолжить;
		КонецЕсли;
		
		МассивСсылокПоТипуЗначения = КэшТипов.Получить(ТипСсылки);
		Если МассивСсылокПоТипуЗначения = Неопределено Тогда
			МассивСсылокПоТипуЗначения = Новый Массив;
		КонецЕсли;
		МассивСсылокПоТипуЗначения.Добавить(ЗначениеСсылки);
		КэшТипов.Вставить(ТипСсылки, МассивСсылокПоТипуЗначения);
	КонецЦикла;
	
	Для Каждого СтрочкаТипа Из КэшТипов Цикл
		НаименованияРеквизитов = КэшТиповРеквизитов.Получить(СтрочкаТипа.Ключ);
		НаименованиеТипа = Метаданные.НайтиПоТипу(СтрочкаТипа.Ключ).ПолноеИмя();
		Если НаименованияРеквизитов = Неопределено Тогда
			Если Перечисления.ТипВсеСсылки().СодержитТип(СтрочкаТипа.Ключ) Тогда
				Для Каждого СтрочкаСсылки Из СтрочкаТипа.Значение Цикл
					СтруктураРеквизита = Новый Структура;
					СтруктураРеквизита.Вставить("Наименование", XMLСтрока(СтрочкаСсылки));
					СтруктураРеквизита.Вставить("ТипЗначения", НаименованиеТипа);
					КэшСсылок.Вставить(СтрочкаСсылки, СтруктураРеквизита);
				КонецЦикла;		
			Иначе
				Для Каждого СтрочкаСсылки Из СтрочкаТипа.Значение Цикл 
					//+ КАМИ 07.02.2024 13:17:58 Гросу Р.И. №  
					СтруктураРеквизита = ПолучитьПростуюСтруктуруПоСсылке(СтрочкаСсылки);
					Если СтруктураРеквизита = "" Тогда
					//- КАМИ 07.02.2024 13:20:44 Гросу Р.И. 
						СтруктураРеквизита = Новый Структура;
						СтруктураРеквизита.Вставить("УИД", XMLСтрока(СтрочкаСсылки));
						СтруктураРеквизита.Вставить("Ссылка", XMLСтрока(СтрочкаСсылки));
						СтруктураРеквизита.Вставить("ТипЗначения", НаименованиеТипа);   
					//+ КАМИ 07.02.2024 13:20:48 Гросу Р.И. №
					КонецЕсли;
					//- КАМИ 07.02.2024 13:18:02 Гросу Р.И. 
					КэшСсылок.Вставить(СтрочкаСсылки, СтруктураРеквизита);
				КонецЦикла;
			КонецЕсли;
		Иначе
			МассивРеквизитов = ОбщегоНазначения.ЗначенияРеквизитовОбъектов(СтрочкаТипа.Значение, НаименованияРеквизитов);

			Для Каждого СтрочкаСсылки Из МассивРеквизитов Цикл
				СтрочкаСсылки.Значение.Вставить("ТипЗначения", НаименованиеТипа);
				СтруктураРеквизита = Новый Структура;
				Для Каждого Реквизит Из СтрочкаСсылки.Значение Цикл
					НовоеЗначение = Реквизит.Значение;
					Если ТипЗнч(НовоеЗначение) = Тип("Булево")
						ИЛИ ТипЗнч(НовоеЗначение) = Тип("Число")
						ИЛИ ТипЗнч(НовоеЗначение) = Тип("Дата")
						ИЛИ ТипЗнч(НовоеЗначение) = Тип("Строка") Тогда
					ИначеЕсли НЕ ЗначениеЗаполнено(НовоеЗначение) Тогда
						НовоеЗначение = "";
					ИначеЕсли ТипЗнч(НовоеЗначение) = Тип("УникальныйИдентификатор") Тогда
						НовоеЗначение = XMLСтрока(НовоеЗначение);
					КонецЕсли;
					СтруктураРеквизита.Вставить(Реквизит.Ключ, НовоеЗначение);
				КонецЦикла;
				Результат.Вставить(СтрочкаСсылки.Ключ, СтруктураРеквизита);
			КонецЦикла;
		КонецЕсли;
	КонецЦикла;
	
	Возврат Результат;
	
КонецФункции

