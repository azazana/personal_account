Функция ПолучитьТаблицуВГХНоменклатуры(ПараметрыЗапроса) Экспорт
	
	СписокНоменклатуры = ПолучитьСписокСсылокСправочникаИзПараметровЗапроса(ПараметрыЗапроса, "СписокНоменклатуры", "Номенклатура");
	
	Если ОбщегоНазначенияКлиентСервер.ЕстьРеквизитИлиСвойствоОбъекта(ПараметрыЗапроса, "СписокСсылок") Тогда
		Для Каждого ДанныеСсылки Из ПараметрыЗапроса.СписокСсылок Цикл		
			СписокНоменклатуры.Добавить(ДанныеСсылки);
		КонецЦикла;
	КонецЕсли;

	Если СписокНоменклатуры.Количество() = 0 Тогда		
		ДанныеОтвета = новый Структура;
		ДанныеОтвета.Вставить("ТекстОшибки","Не найдена ни одна позиция номенклатуры");    
		ДанныеОтвета.Вставить("ПараметрыЗапроса",ПараметрыЗапроса);
		ДанныеОтвета.Вставить("СтатусОтвета",400);
		Возврат ДанныеОтвета; 
	КонецЕсли;  
	
	мОбъектЗапроса = Новый Запрос;
	мОбъектЗапроса.Текст = ТекстЗапросаВГХНоменклатуры();	
	мОбъектЗапроса.УстановитьПараметр("СписокНоменклатуры", СписокНоменклатуры);
	
	ТаблицаРезультат = мОбъектЗапроса.Выполнить().Выгрузить();      

	ЗаполнитьКэшСсылокПоТаблицеЗначений(ТаблицаРезультат);

	Возврат ТаблицаРезультат;
	
КонецФункции
