		КонецЕсли;		
		Для Каждого СтрокаИдентификатора Из МассивИдентификаторов Цикл
			Если ЗначениеЗаполнено(СтрокаИдентификатора) Тогда
				Идентификаторы.Добавить(СтрокаИдентификатора);
			КонецЕсли;
		КонецЦикла;
	КонецЕсли;
	
	ИзменитьСтатусыСообщений(Идентификаторы, Перечисления.КАМИ_СтатусыОтправкиОбменСервиснаяСлужба.ОшибкаДоставки);
	
	Ответ = Новый Структура;
	
	Ответ.Вставить("РезультатЗапроса", "");
	Ответ.Вставить("ТекстОшибки","");
	Ответ.Вставить("СтатусОтвета",200);
	
	Возврат Ответ;

КонецФункции

Функция ПолучитьИзмененияДляОбмена() Экспорт
	  	
	Ответ = Новый Структура;
	
	Ответ.Вставить("РезультатЗапроса", "");
	Ответ.Вставить("ТекстОшибки","");
	Ответ.Вставить("СтатусОтвета",200);
	
	УзелДляОбмена = ПланыОбмена.КАМИ_ОбменСервиснаяСлужба.НайтиПоНаименованию("Сервисная служба");
	
	Если Не ЗначениеЗаполнено(УзелДляОбмена) Тогда
		Возврат Ответ;
	КонецЕсли;
	
	ТЗ = ПолучитьСписокПланаОбмена("КАМИ_ОбменСервиснаяСлужба"); 
	
	ТекстыЗапроса = Новый Массив;
	Для Каждого СтрочкаОбъекта Из ТЗ Цикл
		ТекстЗапроса ="ВЫБРАТЬ
		              |	ТИПЗНАЧЕНИЯ(ТаблицаИзменений.Ссылка) КАК ТипСсылки,
		              |	ТаблицаИзменений.Ссылка КАК Ссылка
		              |ИЗ
		              |	"+ СтрочкаОбъекта.ОбъектКонфигурации + ".Изменения КАК ТаблицаИзменений
		              |ГДЕ
		              |	ТаблицаИзменений.Узел = &УзелОбмена";
		ТекстыЗапроса.Добавить(ТекстЗапроса);
	КонецЦикла;
			
	Если ТекстыЗапроса.Количество() = 0 Тогда
		Возврат Ответ;
	КонецЕсли;
	
	ОбщийТекст = СтрСоединить(ТекстыЗапроса, ОбщегоНазначенияУТ.РазделительЗапросовВОбъединении(Истина));
	
	ОбщийТекст = ОбщийТекст + "		              
	|ИТОГИ ПО
	|	ТипСсылки";
	
	мЗапрос = Новый Запрос;
	мЗапрос.Текст = ОбщийТекст;
	
	мЗапрос.УстановитьПараметр("УзелОбмена", УзелДляОбмена);
	
	мВыборкаТипов = мЗапрос.Выполнить().Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам);
	
	Сообщения = Новый Массив;
	
	Пока мВыборкаТипов.Следующий() Цикл
		
		СписокСсылок = Новый Массив;
		мВыборкаСсылок = мВыборкаТипов.Выбрать();
		Пока мВыборкаСсылок.Следующий() Цикл  
			СписокСсылок.Добавить(мВыборкаСсылок.Ссылка);
		КонецЦикла;
		
		Если СписокСсылок.Количество() > 0 Тогда   
			
			ТекущийОтвет = СформироватьСообщенияПоИзменениям(мВыборкаТипов.ТипСсылки, СписокСсылок); 
			
			Если ТипЗнч(ТекущийОтвет) = Тип("Структура") 
				И ТекущийОтвет.Свойство("СтатусОтвета") 
				И ТекущийОтвет.СтатусОтвета = 200 Тогда   
				
				ПланыОбмена.УдалитьРегистрациюИзменений(УзелДляОбмена, СписокСсылок); 
				
				СтруктураСообщения = Новый Структура;
				СтруктураСообщения.Вставить("ВидСообщения", ТекущийОтвет.РезультатЗапроса.ВидСообщения);
				СтруктураСообщения.Вставить("КоличествоСообщений", ТекущийОтвет.РезультатЗапроса.КоличествоСообщений); 
				СтруктураСообщения.Вставить("Идентификаторы", ТекущийОтвет.РезультатЗапроса.Идентификаторы);

				Сообщения.Добавить(СтруктураСообщения);
			КонецЕсли;
		КонецЕсли;    
	КонецЦикла;  
	//+ КАМИ 25.11.2023 22:12:39 Гросу Р.И. №
	ОчиститьУстаревшиеСообщения(5);
	//- КАМИ 25.11.2023 22:12:44 Гросу Р.И. 
	Если Сообщения.Количество() Тогда
		Ответ.Вставить("РезультатЗапроса", Сообщения);
	КонецЕсли;
	Возврат Ответ;
	
КонецФункции

