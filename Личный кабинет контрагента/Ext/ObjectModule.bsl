Функция ПечатнаяФормаДокумента(ДокументСсылка, ИмяМакета) 
	
	ТабДокумент = Неопределено;
	
	МенеджерПечати = "Документ." + ДокументСсылка.Метаданные().Имя; 
	ИмяМакетаПечати = ИмяМакета;
	ДополнительныеПараметры = Новый Структура;

	МассивОбъектов = Новый Массив;
	МассивОбъектов.Добавить(ДокументСсылка);
	КомандыПечати = УправлениеПечатью.КомандыПечатиОбъектаДоступныеДляВложений(ДокументСсылка.Метаданные()); 
	НайденныеСтроки = КомандыПечати.НайтиСтроки(Новый Структура("Представление", ИмяМакета));  
	Если НайденныеСтроки.Количество() > 0 Тогда
		МенеджерПечати = НайденныеСтроки.Получить(0).МенеджерПечати; 
		ИмяМакетаПечати = НайденныеСтроки.Получить(0).Идентификатор;
		ДополнительныеПараметры = НайденныеСтроки.Получить(0).ДополнительныеПараметры; 
	Иначе
		НайденныеСтроки = КомандыПечати.НайтиСтроки(Новый Структура("Идентификатор", ИмяМакета));  
		Если НайденныеСтроки.Количество() > 0 Тогда
			МенеджерПечати = НайденныеСтроки.Получить(0).МенеджерПечати; 
			ИмяМакетаПечати = НайденныеСтроки.Получить(0).Идентификатор;
			ДополнительныеПараметры = НайденныеСтроки.Получить(0).ДополнительныеПараметры;
		КонецЕсли;
	КонецЕсли;
	КоллекцияПФ = Неопределено; 
	
	КоллекцияПФ = УправлениеПечатью.СформироватьПечатныеФормы(МенеджерПечати, ИмяМакетаПечати, МассивОбъектов, ДополнительныеПараметры);
	Для Каждого Стр Из КоллекцияПФ.КоллекцияПечатныхФорм Цикл
		ТабДокумент = Стр.ТабличныйДокумент;
		Прервать;
	КонецЦикла;
	
	Возврат ТабДокумент;
	
КонецФункции
