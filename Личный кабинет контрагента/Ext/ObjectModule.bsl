Функция ПолучитьМассивОписанийФайлов(МассивСсылок, ВключаяПомеченныеНаУдаление = Ложь, ПолучатьДвоичныеДанные = Ложь) Экспорт
	
	Если ТипЗнч(МассивСсылок) <> Тип("Массив") Тогда
		Возврат "";
	КонецЕсли;   
	
	ОписанияФайлов = ПолучитьОписанияФайлов(МассивСсылок, ВключаяПомеченныеНаУдаление, ПолучатьДвоичныеДанные);
	
	Если ОписанияФайлов = Неопределено Тогда
		Возврат "";
	КонецЕсли;
	
	//    * Ссылка                             - ОпределяемыйТип.ПрисоединенныйФайл - ссылка на элемент справочника с файлом.
	//    * СсылкаНаДвоичныеДанныеФайла        - Строка - адрес во временном хранилище, по которому помещены данные файла.
	//    * Владелец                           - ОпределяемыйТип.ВладелецФайлов - ссылка объект-владелец файла.
	//    * ОтносительныйПуть                  - Строка - относительный путь файла. 
	//    * ДатаМодификацииУниверсальная       - Дата   - дата изменения файла в UTC.
	//    * ИмяФайла                           - Строка - имя файла, например, "документ.txt".
	//    * Наименование                       - Строка - наименование файла (в справочнике хранения файлов).
	//    * Расширение                         - Строка - расширение файла без точки.
	//    * Размер                             - Число  - размер файла в байтах.
	
	МассивСтруктур = Новый Массив;
	Для Каждого СписокФайлов Из ОписанияФайлов Цикл
		НоваяСтруктура = Новый Структура;
		НоваяСтруктура.Вставить("Владелец", ПолучитьПростуюСтруктуруПоСсылке(СписокФайлов.Ключ));
		МассивФайлов = Новый Массив;
		Для Каждого ОписаниеФайла Из СписокФайлов.Значение Цикл
			СтруктураФайла = Новый Структура("ИмяФайла, Наименование, ПутьКФайлу, Расширение, Размер");
			ЗаполнитьЗначенияСвойств(СтруктураФайла, ОписаниеФайла);
			СтруктураФайла.Вставить("ТипФайла", ПолучитьТипФайла(ОписаниеФайла.Ссылка)); 
			Если ПолучатьДвоичныеДанные = Истина Тогда
				ДвоичныеДанные = ПолучитьИзВременногоХранилища(ОписаниеФайла.СсылкаНаДвоичныеДанныеФайла);
				ДанныеФайла = Base64Строка(ДвоичныеДанные);			
				СтруктураФайла.Вставить("Данные", ДанныеФайла);
			КонецЕсли;
			МассивФайлов.Добавить(СтруктураФайла);
		КонецЦикла;
		НоваяСтруктура.Вставить("Файлы", МассивФайлов); 
		МассивСтруктур.Добавить(НоваяСтруктура);
	КонецЦикла;
		
	Возврат МассивСтруктур;
	
КонецФункции
