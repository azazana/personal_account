	ИначеЕсли ОбщегоНазначенияКлиентСервер.ЕстьРеквизитИлиСвойствоОбъекта(ПараметрыЗапроса, "Дата") Тогда 
		НачалоПериода =  XMLЗначение(Тип("Дата"), ПараметрыЗапроса.Дата); 
	Иначе
		НачалоПериода = ТекущаяДата();
	КонецЕсли;
	
	Если НачалоПериода = Дата(1,1,1) Тогда
		НачалоПериода = ТекущаяДата();
	КонецЕсли;
	
	Если ОбщегоНазначенияКлиентСервер.ЕстьРеквизитИлиСвойствоОбъекта(ПараметрыЗапроса, "КонецПериода") Тогда 
