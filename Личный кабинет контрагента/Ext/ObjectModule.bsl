//+ КАМИ 24.07.2023 16:21:55 Гросу Р.И. № 327085
Процедура ДополнитьМассивСсылокПоМассивуСтруктур(МассивСтруктур, СписокТиповСсылок, КэшНайденныхСсылок, КАМИ_ОбменДаннымиОбработка = Неопределено) 
	
	Если КАМИ_ОбменДаннымиОбработка = Неопределено Тогда
		КАМИ_ОбменДаннымиОбработка = Обработки.КАМИ_ОбменДанными.Создать();
	КонецЕсли;   
	
	Если СписокТиповСсылок = Неопределено Тогда
		СписокТиповСсылок = Новый Соответствие;
	КонецЕсли; 
	
	Если КэшНайденныхСсылок = Неопределено Тогда
		КэшНайденныхСсылок = Новый Соответствие;
	КонецЕсли; 
	
	Для Каждого ЭлементМассива Из МассивСтруктур Цикл  
		Если ТипЗнч(ЭлементМассива) = Тип("Структура") Тогда
			СтруктураСтроки = ЭлементМассива;	
		ИначеЕсли ТипЗнч(ЭлементМассива) = Тип("КлючИЗначение")
			И ТипЗнч(ЭлементМассива.Значение) = Тип("Структура") Тогда
			Если ЭлементМассива.Значение.Свойство("ШапкаДокумента") Тогда
				СтруктураСтроки = ЭлементМассива.Значение.ШапкаДокумента;
			Иначе
				СтруктураСтроки = ЭлементМассива.Значение;
			КонецЕсли;
		Иначе
			Продолжить;
		КонецЕсли;
		Для Каждого Реквизит Из СтруктураСтроки Цикл
			Если ТипЗнч(Реквизит.Значение) = Тип("Структура") Тогда  
				СтруктураРеквизита = Реквизит.Значение;
				Если СтруктураРеквизита.Свойство("ТипЗначения") И ЗначениеЗаполнено(СтруктураРеквизита.ТипЗначения) Тогда
					МассивСсылок = СписокТиповСсылок.Получить(СтруктураРеквизита.ТипЗначения);
					Если МассивСсылок = Неопределено Тогда
						МассивСсылок = Новый Соответствие;
					КонецЕсли;            
					Если СтруктураРеквизита.Свойство("Ссылка") И ЗначениеЗаполнено(СтруктураРеквизита.Ссылка) Тогда
						МассивСсылок.Вставить(СтруктураРеквизита.Ссылка, СтруктураРеквизита); 
					ИначеЕсли СтрНайти(СтруктураРеквизита.ТипЗначения, "Перечисление.") = 1 Тогда
						МассивСсылок.Вставить(СтруктураРеквизита.Наименование, СтруктураРеквизита); 
					ИначеЕсли СтрНайти(СтруктураРеквизита.ТипЗначения, "Справочник.Пользователи") = 1 Тогда
						МассивСсылок.Вставить(СтруктураРеквизита.ИдентификаторПользователяИБ, СтруктураРеквизита);
					КонецЕсли;
					СписокТиповСсылок.Вставить(СтруктураРеквизита.ТипЗначения, МассивСсылок);
				КонецЕсли;
			КонецЕсли;
		КонецЦикла; 
	КонецЦикла;
	
КонецПроцедуры
