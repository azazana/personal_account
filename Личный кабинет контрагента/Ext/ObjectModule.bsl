//+ КАМИ 04.10.2024 18:17:22 Гросу Р.И. № 0000033652
Функция Структура_QRКодВозвратДС(СписаниеБезналичныхДС, СуммаПлатежа = 0)

	Если Ложь Тогда 
		СписаниеБезналичныхДС = Документы.СписаниеБезналичныхДенежныхСредств.ПустаяСсылка();
	КонецЕсли;

	Если НЕ ТипЗнч(СписаниеБезналичныхДС.БанковскийСчет) = Тип("СправочникСсылка.БанковскиеСчетаОрганизаций") Тогда
		Возврат "";
	КонецЕсли;
	
	СтруктураВозврата = Новый Структура;
		
	Банк       = СписаниеБезналичныхДС.БанковскийСчет.Банк;
	БИК        = Банк.Код;
	КоррСчет   = Банк.КоррСчет;
	ГородБанка = Банк.Город;
	НомерСчета = СписаниеБезналичныхДС.БанковскийСчет.НомерСчета;
	СписаниеБезналичныхДСТекст = "Списание безналичных ДС " + СписаниеБезналичныхДС.Номер 
	+ " от " + Формат(СписаниеБезналичныхДС.ДатаВходящегоДокумента, "ДФ=dd.MM.yyyy");
	
	НазначениеПлатежаДляQR = "Возврат подоотчетных денежных средств от " 
	+ СписаниеБезналичныхДС.ПодотчетноеЛицо.Наименование 
	+ " по п/п " + (СписаниеБезналичныхДС.НомерВходящегоДокумента)
	+ " от " + Формат(СписаниеБезналичныхДС.ДатаВходящегоДокумента, "ДФ=dd.MM.yyyy") 
	+ " г." + " Без НДС."; 
	
	
	СтруктураВозврата.Вставить("ИННПолучателя", СписаниеБезналичныхДС.Организация.ИНН); 
	СтруктураВозврата.Вставить("КПППолучателя", СписаниеБезналичныхДС.Организация.КПП);
	СтруктураВозврата.Вставить("БИКБанкаПолучателя", СокрЛП(БИК)); 
	СтруктураВозврата.Вставить("НаименованиеБанкаПолучателя", СокрЛП(СписаниеБезналичныхДС.БанковскийСчет.Банк.Наименование));
	СтруктураВозврата.Вставить("НомерСчетаПолучателя", НомерСчета);
	СтруктураВозврата.Вставить("СписаниеБезналичныхДС", СписаниеБезналичныхДСТекст);  
	СтруктураВозврата.Вставить("ТекстПолучателя", СокрЛП(СписаниеБезналичныхДС.Организация.НаименованиеПолное));  
	СтруктураВозврата.Вставить("СчетБанкаПолучателя", КоррСчет); 
	СтруктураВозврата.Вставить("НазначениеПлатежа", НазначениеПлатежаДляQR);   
	СтруктураВозврата.Вставить("СуммаПлатежа", СуммаПлатежа); 
		
	РеквизитыПлатежа = Новый Структура;
	РеквизитыПлатежа.Вставить("ИННПолучателя", СписаниеБезналичныхДС.Организация.ИНН);	
	РеквизитыПлатежа.Вставить("КПППолучателя", СписаниеБезналичныхДС.Организация.КПП);
	РеквизитыПлатежа.Вставить("БИКБанкаПолучателя", СокрЛП(БИК));
	РеквизитыПлатежа.Вставить("ИмяПлательщика", "");
	
	Если ЗначениеЗаполнено(СуммаПлатежа) Тогда
		РеквизитыПлатежа.Вставить("СуммаЧислом", СуммаПлатежа);
	КонецЕсли;
	
	РеквизитыПлатежа.Вставить("НазначениеПлатежа", СокрЛП(НазначениеПлатежаДляQR));
	РеквизитыПлатежа.Вставить("НаименованиеБанкаПолучателя", СокрЛП(СписаниеБезналичныхДС.БанковскийСчет.Банк.Наименование));
	РеквизитыПлатежа.Вставить("НомерСчетаПолучателя", НомерСчета);
	РеквизитыПлатежа.Вставить("ОтчествоПлательщика", "");
	РеквизитыПлатежа.Вставить("Ссылка", СписаниеБезналичныхДС);
	РеквизитыПлатежа.Вставить("СчетБанкаПолучателя", СписаниеБезналичныхДС.БанковскийСчет.Банк.КоррСчет);
	РеквизитыПлатежа.Вставить("ТекстПолучателя", СокрЛП(СписаниеБезналичныхДС.Организация.НаименованиеПолное));
	РеквизитыПлатежа.Вставить("ФамилияПлательщика", "");
	
	QRСтрока = УправлениеПечатьюРФ.ФорматнаяСтрокаУФЭБС(РеквизитыПлатежа);
	Если НЕ ПустаяСтрока(QRСтрока) Тогда
		ДанныеQRКода = ГенерацияШтрихкода.ДанныеQRКода(QRСтрока, 1, 120);
		
		Если ТипЗнч(ДанныеQRКода) = Тип("ДвоичныеДанные") Тогда
			
			КартинкаQRКода = Новый Картинка(ДанныеQRКода);
			РасширениеКартинки = КартинкаQRКода.Формат();
			
			СтруктураФайла = Новый Структура;
			СтруктураФайла.Вставить("ТипФайла", Строка(РасширениеКартинки)); 
			ДанныеФайла = Base64Строка(ДанныеQRКода);			
			СтруктураФайла.Вставить("Данные", ДанныеФайла);
			СтруктураВозврата.Вставить("QR", СтруктураФайла);
		КонецЕсли; 
		
	КонецЕсли;
	
	Возврат СтруктураВозврата;
	
КонецФункции // Структура_QRКодВозвратДС()
