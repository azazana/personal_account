Функция ИерархияНоменклатуры(ПараметрыЗапроса) Экспорт
	Запрос = Новый Запрос;
	Запрос.Текст = 
	"ВЫБРАТЬ
	|	Номенклатура.Код КАК Код,
	|	Номенклатура.Наименование КАК Наименование,
	|	isNull(Номенклатура.Родитель.Код, """") КАК РодительКод
	|ИЗ
	|	Справочник.Номенклатура КАК Номенклатура
	|ГДЕ
	|	Номенклатура.ЭтоГруппа
	//|	И Номенклатура.Ссылка В ИЕРАРХИИ(&Ссылка)
	|
	|УПОРЯДОЧИТЬ ПО
	|	Наименование";
	Запрос.УстановитьПараметр("Ссылка", Справочники.Номенклатура.НайтиПоКоду("00-00442632"));
	РезультатЗапроса = Запрос.Выполнить();
	
	Иерархия = Новый Массив;
	
	Выборка = РезультатЗапроса.Выбрать();
	Пока Выборка.Следующий() Цикл
		Строка = Новый Структура("Код,Наименование,РодительКод");	
		ЗаполнитьЗначенияСвойств(Строка, Выборка);
		Иерархия.Добавить(Строка);
	КонецЦикла;
	
	Ответ = Новый Структура;
	
	Ответ.Вставить("РезультатЗапроса", Новый Структура("Иерархия", Иерархия));
