Процедура ЗаполнитьКэшНайденныхСсылок(СписокТиповСсылок, КэшНайденныхСсылок, КАМИ_ОбменДаннымиОбработка = Неопределено) 
	
	Если КАМИ_ОбменДаннымиОбработка = Неопределено Тогда
		КАМИ_ОбменДаннымиОбработка = Обработки.КАМИ_ОбменДанными.Создать();
	КонецЕсли;   
	
	Если СписокТиповСсылок = Неопределено Тогда
		СписокТиповСсылок = Новый Соответствие;
	КонецЕсли; 
	
	Если КэшНайденныхСсылок = Неопределено Тогда
		КэшНайденныхСсылок = Новый Соответствие;
	КонецЕсли; 
			
	Для Каждого ТипСсылокЭлемент Из СписокТиповСсылок Цикл
		ТипЗначенияСсылки = ТипСсылокЭлемент.Ключ;
		МассивСсылок = ТипСсылокЭлемент.Значение;
		Если СтрНайти(ТипЗначенияСсылки, "Справочник.") = 1 Тогда
			НаименованиеСправочника = СтрЗаменить(ТипЗначенияСсылки, "Справочник.", "");
			Для Каждого ЭлементСсылки Из МассивСсылок Цикл
				Найденыш = КАМИ_ОбменДаннымиОбработка.ПолучитьЗначениеПоСтруктуре(ЭлементСсылки.Значение);
				Если ЗначениеЗаполнено(Найденыш) Тогда
					КэшНайденныхСсылок.Вставить(ЭлементСсылки.Ключ, Найденыш); 
				ИначеЕсли НаименованиеСправочника = "Контрагенты" Тогда
					Найденыш = КАМИ_ОбменДаннымиОбработка.ПолучитьЗначениеСсылкиСправочника(ЭлементСсылки.Значение);
					Если ЗначениеЗаполнено(Найденыш) Тогда
						КэшНайденныхСсылок.Вставить(ЭлементСсылки.Ключ, Найденыш);
					КонецЕсли;  
				ИначеЕсли НаименованиеСправочника = "Пользователи" Тогда
					Найденыш = ПолучитьЗначениеПользователяПоСтруктуре(ЭлементСсылки.Значение);
					Если ЗначениеЗаполнено(Найденыш) Тогда
						КэшНайденныхСсылок.Вставить(ЭлементСсылки.Ключ, Найденыш);
					КонецЕсли;  
				КонецЕсли;
			КонецЦикла;
		ИначеЕсли СтрНайти(ТипЗначенияСсылки, "Документ.") = 1 Тогда 
			НаименованиеДокумента = СтрЗаменить(ТипЗначенияСсылки, "Документ.", "");
			Для Каждого ЭлементСсылки Из МассивСсылок Цикл
				Найденыш = КАМИ_ОбменДаннымиОбработка.ПолучитьСсылкуДокумента(НаименованиеДокумента, ЭлементСсылки.Ключ, Неопределено);
				Если ЗначениеЗаполнено(Найденыш) Тогда
					КэшНайденныхСсылок.Вставить(ЭлементСсылки.Ключ, Найденыш);
				КонецЕсли;
			КонецЦикла;	 
		ИначеЕсли СтрНайти(ТипЗначенияСсылки, "Перечисление.") = 1 Тогда 
			НаименованиеПеречисления = СтрЗаменить(ТипЗначенияСсылки, "Перечисление.", "");
			Для Каждого ЭлементСсылки Из МассивСсылок Цикл
				Найденыш = КАМИ_ОбменДаннымиОбработка.ПолучитьЗначениеПеречисления(НаименованиеПеречисления, ЭлементСсылки.Ключ);
				Если ЗначениеЗаполнено(Найденыш) Тогда
					КэшНайденныхСсылок.Вставить(ЭлементСсылки.Ключ, Найденыш);
				КонецЕсли;
			КонецЦикла;	
		КонецЕсли;
	КонецЦикла;
	
КонецПроцедуры
