Функция СоздатьСтруктуруСтрокиСНайденнымиСсылками(ВходящаяСтруктура, КэшНайденныхСсылок, КАМИ_ОбменДаннымиОбработка) 
	
	РеквизитыТипДата = Новый Массив;
	РеквизитыТипДата.Добавить("Дата");
	РеквизитыТипДата.Добавить("ДатаОкончания");
	РеквизитыТипДата.Добавить("ДатаГотовностиПредварительная");
	РеквизитыТипДата.Добавить("ДатаНачалаКомандировки");
	РеквизитыТипДата.Добавить("ДатаОкончанияКомандировки");
	РеквизитыТипДата.Добавить("ДатаГотовности");

	РеквизитыТипУИД = Новый Массив;
	РеквизитыТипУИД.Добавить("КлючСвязи");
	РеквизитыТипУИД.Добавить("КлючСвязиВыезды");
	РеквизитыТипУИД.Добавить("КлючСвязиТовары");
	
	НоваяСтруктураСтроки = Новый Структура;
	Для Каждого Реквизит Из ВходящаяСтруктура Цикл     
		Найденыш = Неопределено;
		Если ТипЗнч(Реквизит.Значение) = Тип("Структура") Тогда  
			Если Реквизит.Значение.Свойство("Ссылка") И ЗначениеЗаполнено(Реквизит.Значение.Ссылка) Тогда
				Найденыш = КэшНайденныхСсылок.Получить(Реквизит.Значение.Ссылка);   
			ИначеЕсли Реквизит.Значение.Свойство("ТипЗначения") И ЗначениеЗаполнено(Реквизит.Значение.ТипЗначения) И СтрНайти(Реквизит.Значение.ТипЗначения, "Перечисление.") Тогда
				Найденыш = КэшНайденныхСсылок.Получить(Реквизит.Значение.Наименование); 
			ИначеЕсли Реквизит.Значение.Свойство("ИдентификаторПользователяИБ") И ЗначениеЗаполнено(Реквизит.Значение.ИдентификаторПользователяИБ) Тогда
				Найденыш = КэшНайденныхСсылок.Получить(Реквизит.Значение.ИдентификаторПользователяИБ); 
			КонецЕсли;				
			//ИначеЕсли ТипЗнч(Реквизит) = Тип("Массив") Тогда
		ИначеЕсли ТипЗнч(Реквизит.Значение) = Тип("Число") Тогда 
			Найденыш = КАМИ_ОбменДаннымиОбработка.ПолучитьЗначениеЧисла(Реквизит.Значение)
		ИначеЕсли ТипЗнч(Реквизит.Значение) = Тип("Строка") Тогда 
			Если РеквизитыТипДата.Найти(Реквизит.Ключ) <> Неопределено Тогда
				Найденыш = КАМИ_ОбменДаннымиОбработка.ПолучитьЗначениеДаты(Реквизит.Значение)
			ИначеЕсли РеквизитыТипУИД.Найти(Реквизит.Ключ) <> Неопределено Тогда 
				Если ЗначениеЗаполнено(Реквизит.Значение) Тогда
					Найденыш = Новый УникальныйИдентификатор(Реквизит.Значение);
				Иначе   
					Найденыш = Новый УникальныйИдентификатор(ПустойИдентификатор);
				КонецЕсли;
			Иначе
				Найденыш = КАМИ_ОбменДаннымиОбработка.ПолучитьЗначениеСтроки(Реквизит.Значение); 
			КонецЕсли;
		ИначеЕсли ТипЗнч(Реквизит.Значение) = Тип("Дата") Тогда 
			Найденыш = КАМИ_ОбменДаннымиОбработка.ПолучитьЗначениеДаты(Реквизит.Значение);
		ИначеЕсли ТипЗнч(Реквизит.Значение) = Тип("Булево") Тогда  
			Найденыш = КАМИ_ОбменДаннымиОбработка.ПолучитьЗначениеБулево(Реквизит.Значение) ;
		КонецЕсли; 
		НоваяСтруктураСтроки.Вставить(Реквизит.Ключ, Найденыш);
	КонецЦикла;
	
	Возврат НоваяСтруктураСтроки;
КонецФункции
