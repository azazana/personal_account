Функция ПолучитьПечатныеФормыДокументов(ПараметрыЗапроса) Экспорт
	
	///// Массив структур вида:
	/// Владелец - ссылка на владельца файлов
	/// ОписаниеВладельца - структура с описанием ссылки на владельца
	/// Файлы - массив структур с описаниями файлов
	СписокСсылок = РаспознатьСсылкиДокументов(ПараметрыЗапроса);
	
	//РезультатЗапроса = ПолучитьТаблицуФайловСервисныхРабот(ПараметрыЗапроса);
	РезультатЗапроса = Новый Массив;
	Для Каждого СтрочкаДокумента Из СписокСсылок Цикл
		
		//ГУИД = ЗапросПараметры.GUID;
		//ТипДокумента = ЗапросПараметры.DocumentType;
		ТипПечатнойФормы = ""; //ЗапросПараметры.ТипПечатнойФормы;
		РасширениеПечатнойФормы = ""; //ЗапросПараметры.РасширениеПечатнойФормы; 
		Если СтрочкаДокумента.Параметры.Свойство("ТипПечатнойФормы", ТипПечатнойФормы) = Ложь Тогда
			Продолжить;
		КонецЕсли;
		Если СтрочкаДокумента.Параметры.Свойство("РасширениеПечатнойФормы", РасширениеПечатнойФормы) = Ложь Тогда
			РасширениеПечатнойФормы = "pdf";
		КонецЕсли;                          
		
		ПечатнаяФорма = ПолучитьПечатнуюФормуДокумента(СтрочкаДокумента.Ссылка, ТипПечатнойФормы, РасширениеПечатнойФормы);
		
		Если НЕ ЗначениеЗаполнено(ПечатнаяФорма) Тогда
			Продолжить;
		КонецЕсли;
		
		СтруктураОтвета = Новый Структура;
		СтруктураОтвета.Вставить("Ссылка", СтрочкаДокумента.Параметры.Ссылка);
		СтруктураОтвета.Вставить("ТипПечатнойФормы", ТипПечатнойФормы);
		СтруктураОтвета.Вставить("РасширениеПечатнойФормы", РасширениеПечатнойФормы);
		СтруктураОтвета.Вставить("ПечатнаяФорма", ПечатнаяФорма); 
		РезультатЗапроса.Добавить(СтруктураОтвета);
		
	КонецЦикла;
	
	
	Ответ = Новый Структура;
	
	Ответ.Вставить("РезультатЗапроса", РезультатЗапроса);
	Ответ.Вставить("ТекстОшибки","");
	Ответ.Вставить("СтатусОтвета",200);
	
	Возврат Ответ;
	
КонецФункции
