Функция ПолучитьТаблицуИзЗапросаИЗаполнитьКэшСсылок(РезультатыЗапроса, НомерТаблицы, Индексы = "") Экспорт

	Если НомерТаблицы >= РезультатыЗапроса.Количество() Тогда
		Возврат Неопределено;
	КонецЕсли;
	
	ТаблицаРезультата = РезультатыЗапроса[НомерТаблицы].Выгрузить(); 
	
	МассивИндексов = Новый Массив;
	
	Если ТипЗнч(Индексы) = Тип("Строка") Тогда
		МассивИндексов = СтрРазделить(Индексы, ",", Ложь);
	ИначеЕсли ТипЗнч(Индексы) = Тип("Массив") Тогда
		МассивИндексов = Индексы;
	КонецЕсли; 
	
	Для Каждого Индекс Из МассивИндексов Цикл
		Если ТаблицаРезультата.Колонки.Найти(Индекс) <> Неопределено Тогда
			ТаблицаРезультата.Индексы.Добавить(Индекс);
		КонецЕсли;
	КонецЦикла;
	
	ЗаполнитьКэшСсылокПоТаблицеЗначений(ТаблицаРезультата);
	
	Возврат ТаблицаРезультата;
	
КонецФункции

Процедура ЗаменитьСсылкиВМассивеСтруктурПоКэшуСсылок(МассивСтруктур) Экспорт
	
	Для Каждого СтруктураСтроки Из МассивСтруктур Цикл 
		Если Ложь Тогда
			СтруктураСтроки = Новый Структура;
		КонецЕсли;
		НоваяСтруктура = Новый Структура;
		Для Каждого ЭлементСтруктуры Из СтруктураСтроки Цикл
			Если ЭтоСсылка(ТипЗнч(ЭлементСтруктуры.Значение)) Тогда
				НоваяСтруктура.Вставить(ЭлементСтруктуры.Ключ, 	КэшСсылок.Получить(ЭлементСтруктуры.Значение)); 
			//+ КАМИ 27.07.2023 17:00:27 Гросу Р.И. № 327085
			ИначеЕсли ТипЗнч(ЭлементСтруктуры.Значение) = Тип("УникальныйИдентификатор") Тогда
				НоваяСтруктура.Вставить(ЭлементСтруктуры.Ключ, 	XMLСтрока(ЭлементСтруктуры.Значение)); 
			//- КАМИ 27.07.2023 17:00:29 Гросу Р.И. 
			КонецЕсли;
		КонецЦикла;
		Для Каждого НовыйЭлемент Из НоваяСтруктура Цикл
			СтруктураСтроки.Вставить(НовыйЭлемент.Ключ, НовыйЭлемент.Значение);
		КонецЦикла;
	КонецЦикла;
	
КонецПроцедуры

Функция ПолучитьТабличнуюЧастьПоКэшуСсылок(ТабличнаяЧасть, Отбор) Экспорт
	
	ТабличнаяЧастьОтбор = ТабличнаяЧасть.Скопировать(Отбор);
	Для Каждого ЭлементОтбора Из Отбор Цикл
		ТабличнаяЧастьОтбор.Колонки.Удалить(ЭлементОтбора.Ключ);
	КонецЦикла;
	
	МассивСтруктур = ОбщегоНазначения.ТаблицаЗначенийВМассив(ТабличнаяЧастьОтбор); 
	ЗаменитьСсылкиВМассивеСтруктурПоКэшуСсылок(МассивСтруктур);
	
	Возврат МассивСтруктур;
	
КонецФункции

Функция ДополнитьРезультатТабличнымиЧастями(РезультатыЗапроса, ТаблицаРезультатаИсходный, ТабличныеЧастиРезультата, ПоляОтбора = "Ссылка")
	
	Если ТипЗнч(ТаблицаРезультатаИсходный) = Тип("ТаблицаЗначений") Тогда
		ТаблицаРезультата = ТаблицаРезультатаИсходный.Скопировать();
	ИначеЕсли  ТипЗнч(ТаблицаРезультатаИсходный) = Тип("Число") Тогда
		ТаблицаРезультата = ПолучитьТаблицуИзЗапросаИЗаполнитьКэшСсылок(РезультатыЗапроса, ТаблицаРезультатаИсходный, ПоляОтбора);  
	Иначе
		Возврат Неопределено;
	КонецЕсли;
	
	СтруктураТабличныеЧасти = Новый Структура;
	
	Для Каждого ТабличнаяЧастьРезультата Из ТабличныеЧастиРезультата Цикл
		ТаблицаРезультата.Колонки.Добавить(ТабличнаяЧастьРезультата.Ключ,,ТабличнаяЧастьРезультата.Ключ); 
		ТабличнаяЧастьЗначение = ПолучитьТаблицуИзЗапросаИЗаполнитьКэшСсылок(РезультатыЗапроса, ТабличнаяЧастьРезультата.Значение, ПоляОтбора);
		СтруктураТабличныеЧасти.Вставить(ТабличнаяЧастьРезультата.Ключ, ТабличнаяЧастьЗначение);  
	КонецЦикла;
	
	Для Каждого Строчка Из ТаблицаРезультата Цикл 
