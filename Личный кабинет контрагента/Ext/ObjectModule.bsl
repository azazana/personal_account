	ДатаОтчета = ПараметрыЗапроса.ДатаОтчета;
	Если ТипЗнч(ДатаОтчета) = Тип("Строка") Тогда
		ДатаОтчета = ПрочитатьДатуJSON(ДатаОтчета, ФорматДатыJSON.ISO);	
	КонецЕсли;
	
	Об = ДополнительныеОтчетыИОбработкиВызовСервера.ОбъектВнешнейОбработки(Обработка);
	
	Номенклатура = АРМСкладПолучитьНоменклатуру(ПараметрыЗапроса); 	
	Таблицы = Об.ПолучитьДанныеДляВывода(Номенклатура, ДатаОтчета);  
	Таблицы = АРМСкладДобавитьИерархиюНоменклатуры(Таблицы);
