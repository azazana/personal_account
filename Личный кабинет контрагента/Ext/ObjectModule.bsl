Процедура АРМСкладОбработатьСсылочныеТипы(Данные, СсылочныеТипы)
	Для каждого КлЗн Из Данные Цикл
		Если Данные[КлЗн.Ключ] = null Тогда
			Данные[КлЗн.Ключ] = Неопределено;	
		КонецЕсли;
		Если ОбщегоНазначения.ЭтоСсылка(ТипЗнч(Данные[КлЗн.Ключ])) Тогда
			СсылочныеТипы.Вставить(Данные[КлЗн.Ключ], Истина);	
			Данные[КлЗн.Ключ] = XMLСтрока(Данные[КлЗн.Ключ]);
		КонецЕсли;	
	КонецЦикла;		
КонецПроцедуры

Функция АРМСкладПолучитьОписанияСсылочныхТипов(СсылочныеТипы)
 	ИменаТаблиц = Новый Массив;      
	Ссылки = Новый Массив;
	Для каждого КлЗн Из СсылочныеТипы Цикл
		ИмяТаблицы = ОбщегоНазначения.ИмяТаблицыПоСсылке(КлЗн.Ключ);
		ИменаТаблиц.Добавить(ИмяТаблицы); 
		Ссылки.Добавить(КлЗн.Ключ);
	КонецЦикла; 
	
	ИменаТаблиц = ОбщегоНазначенияУТ.УдалитьПовторяющиесяЭлементыМассива(ИменаТаблиц);
	
	ТекстЗапроса = "";
	
	Для каждого ИмяТаблицы Из ИменаТаблиц Цикл
		Объект = СтрРазделить(ИмяТаблицы, ".")[0];	
		Если Объект = "Справочник" ИЛИ Объект = "Документ" Тогда
			Разрешенные = "РАЗРЕШЕННЫЕ";
			Если НЕ ПустаяСтрока(ТекстЗапроса) Тогда
				ТекстЗапроса = ТекстЗапроса + " ОБЪЕДИНИТЬ ВСЕ ";
				Разрешенные = "";
			КонецЕсли;	 
			ТекстЗапроса = ТекстЗапроса + СтрШаблон("ВЫБРАТЬ %2 А.Ссылка, А.Представление ИЗ %1 КАК А ГДЕ А.Ссылка В (&Ссылки)", ИмяТаблицы, Разрешенные);
		ИначеЕсли Объект = "Перечисление" Тогда
		КонецЕсли;
	КонецЦикла;
	
	Описания = Новый Массив;
	
	Если Не ПустаяСтрока(ТекстЗапроса) Тогда
		Запрос = Новый Запрос;
		Запрос.Текст = ТекстЗапроса;
		Запрос.УстановитьПараметр("Ссылки", Ссылки);   
		
		РезультатЗапроса = Запрос.Выполнить();
		Выборка = РезультатЗапроса.Выбрать();
		Пока Выборка.Следующий() Цикл
			Описания.Добавить(Новый Структура("Ссылка,Представление", XMLСтрока(Выборка.Ссылка), Выборка.Представление));
		КонецЦикла; 
	КонецЕсли; 
	
	Возврат Описания;
КонецФункции
