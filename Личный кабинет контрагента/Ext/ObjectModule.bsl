Функция ПолучитьОписанияКолонокСтруктурой(КолонкиРезультата)
	
	МассивОписаний = Новый Массив;
	Для Каждого Колонка Из КолонкиРезультата Цикл
		МассивТипов = Новый Массив;
		СтруктураКолонки = Новый Структура;
		СтруктураКолонки.Вставить("Имя", Колонка.Имя);
		Для Каждого ТипКолонки Из Колонка.ТипЗначения.Типы() Цикл
			Если НЕ ТипКолонки = Тип("null") Тогда
				Мета = Метаданные.НайтиПоТипу(ТипКолонки);
				Если НЕ Мета = Неопределено Тогда
					НаименованиеТипа = Метаданные.НайтиПоТипу(ТипКолонки).ПолноеИмя();
					Если НЕ НаименованиеТипа = Неопределено Тогда
						МассивТипов.Добавить(НаименованиеТипа);
					КонецЕсли;
				Иначе
					МассивТипов.Добавить(Строка(ТипКолонки));
				КонецЕсли;
			КонецЕсли;
		КонецЦикла;
		СтруктураКолонки.Вставить("ТипыЗначений", МассивТипов);
		МассивОписаний.Добавить(СтруктураКолонки);
	КонецЦикла;
	
	Возврат МассивОписаний;
	
