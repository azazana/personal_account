			ИначеЕсли ОбщегоНазначенияКлиентСервер.ЕстьРеквизитИлиСвойствоОбъекта(ДанныеДокумента, "Ссылка") Тогда
				ГУИДДокумента = ДанныеДокумента.Ссылка;
			Иначе
				ГУИДДокумента = ПустойИдентификатор;
			КонецЕсли;   
			
			СтруктураПоиска = Неопределено;
			Если ОбщегоНазначенияКлиентСервер.ЕстьРеквизитИлиСвойствоОбъекта(ДанныеДокумента, "Дата") 
