Функция ПолучитьРаспределениеИнженеровПоОрганизациям(тСтруктураПараметров)

	ТаблицаРезультат = ПолучитьТаблицуРаспределениеИнженеровПоОрганизациям(тСтруктураПараметров);
	таблицаТолькоПользователи =  ТаблицаРезультат.скопировать();
	таблицаТолькоПользователи.свернуть("Пользователь");
	
	Результат = Новый Массив; 
	
	стрПоискаСтрок = новый Структура("Пользователь");  
	НомерСтроки = 0;
	Для Каждого СтрочкаТаблицы Из таблицаТолькоПользователи Цикл
		
		НомерСтроки = НомерСтроки + 1;
		
		СтруктураСтроки = Новый Структура;
		СтруктураСтроки.Вставить("Пользователь", Строка(СтрочкаТаблицы.Пользователь));	
		
		стрПоискаСтрок.Пользователь =  СтрочкаТаблицы.Пользователь;
		найдСтроки = ТаблицаРезультат.НайтиСтроки(стрПоискаСтрок);  
		
		массивОрганизаций = новый Массив;
		Для сч2 = 0 по найдСтроки.количество() -1 Цикл
			
			СтрОрганизаций = Новый Структура;
			СтрОрганизаций.Вставить("НаименованиеОрганизации", найдСтроки[сч2].НаименованиеОрганизации);
			СтрОрганизаций.Вставить("ГУИД_Организации", Строка(найдСтроки[сч2].ГУИД_Организации));
			
			массивОрганизаций.Добавить(СтрОрганизаций);
				
		КонецЦикла;
		
		СтруктураСтроки.Вставить("МассивОрганизаций", массивОрганизаций);
		
		Попытка
			СтрокаДляОтвета = УпаковатьОтветВJSON(СтруктураСтроки);
		Исключение    
			ПолноеОписаниеОшибки = "Строка " + Формат(НомерСтроки, "ЧГ=0") + " :" + ПодробноеПредставлениеОшибки(ИнформацияОбОшибке()); 
			#Если Сервер Или ТолстыйКлиентОбычноеПриложение Тогда  
				Сообщить(ПолноеОписаниеОшибки);
			#КонецЕсли			
			Продолжить;
		КонецПопытки;
		
		Результат.Добавить(СтруктураСтроки);
		
	КонецЦикла;
	
	СтруктураРезультата = Новый Структура;
	//СтруктураРезультата.Вставить("ОписаниеПолей", ОписаниеПолей);
	СтруктураРезультата.Вставить("Результат", Результат);
	
	Ответ = Новый Структура;
	
	Ответ.Вставить("РезультатЗапроса", СтруктураРезультата);
	Ответ.Вставить("ТекстОшибки","");
	Ответ.Вставить("СтатусОтвета",200);
	
	Возврат Ответ;

КонецФункции   


Функция ПолучитьТаблицуРаспределениеИнженеровПоОрганизациям(ПараметрыЗапроса) Экспорт
	
	СписокПользователей = Новый Массив;

	Если ОбщегоНазначенияКлиентСервер.ЕстьРеквизитИлиСвойствоОбъекта(ПараметрыЗапроса, "СписокПользователей") Тогда
		Для Каждого ДанныеПользователя Из ПараметрыЗапроса.СписокПользователей Цикл
			Если ЗначениеЗаполнено(ДанныеПользователя)
				И НЕ ДанныеПользователя = ПустойИдентификатор Тогда
				ПользовательИД = Новый УникальныйИдентификатор(ДанныеПользователя);
				СписокПользователей.Добавить(ПользовательИД);
			КонецЕсли;
		КонецЦикла;
	КонецЕсли;

	мОбъектЗапроса = Новый Запрос;
	мОбъектЗапроса.Текст = ТекстЗапросаРаспределениеИнженеровПоОрганизациям();
	
	мОбъектЗапроса.УстановитьПараметр("СписокПользователей", СписокПользователей);
	мОбъектЗапроса.УстановитьПараметр("ОтборПользователей", СписокПользователей.Количество()>0);        
	
	ТаблицаРезультат = мОбъектЗапроса.Выполнить().Выгрузить();      

	Возврат ТаблицаРезультат;
	
КонецФункции
