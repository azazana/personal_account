Функция ПолучитьЗначениеПользователяПоСтруктуре(Значение) Экспорт

	мОбъектЗапроса = Новый Запрос;
	мОбъектЗапроса.Текст = "ВЫБРАТЬ
	                       |	Пользователи.Наименование КАК Наименование,
	                       |	Пользователи.ИдентификаторПользователяИБ КАК ИдентификаторПользователяИБ,
	                       |	Пользователи.Ссылка КАК Ссылка
	                       |ИЗ
	                       |	Справочник.Пользователи КАК Пользователи
	                       |ГДЕ
	                       |	Пользователи.ИдентификаторПользователяИБ В(&СписокПользователей)";
	
	Попытка
		ПользовательИД = Новый УникальныйИдентификатор(Строка(Значение.ИдентификаторПользователяИБ));
	ИСключение
		Возврат Неопределено;
	КонецПопытки;
	
	мОбъектЗапроса.УстановитьПараметр("СписокПользователей", ПользовательИД);
	мОбъектЗапроса.УстановитьПараметр("ОтборПользователей", Истина);        
		
	Выборка = мОбъектЗапроса.Выполнить().Выбрать(); 
	
	Если Выборка.Следующий() Тогда
		Возврат Выборка.Ссылка;
	КонецЕсли;
	
	Возврат Неопределено;
	
КонецФункции
