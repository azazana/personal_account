Функция ИзменитьСервисныеРаботы(ПараметрыЗапроса) Экспорт
	
	СписокДокументов = Новый Соответствие;
		
	Если ОбщегоНазначенияКлиентСервер.ЕстьРеквизитИлиСвойствоОбъекта(ПараметрыЗапроса, "СписокДокументов") Тогда
		Для Каждого ДанныеДокумента Из ПараметрыЗапроса.СписокДокументов Цикл 
			ШапкаДокумента = ДанныеДокумента.ШапкаДокумента;
			ГУИДДокумента = ШапкаДокумента.Ссылка;                                                  
			СтруктураПоиска = Неопределено;
			Если ОбщегоНазначенияКлиентСервер.ЕстьРеквизитИлиСвойствоОбъекта(ШапкаДокумента, "Дата") 
				И ЗначениеЗаполнено(ШапкаДокумента.Дата) Тогда
				СтруктураПоиска = Новый Структура("Дата", XMLЗначение(Тип("Дата"), ШапкаДокумента.Дата));
			КонецЕсли;
			Если ОбщегоНазначенияКлиентСервер.ЕстьРеквизитИлиСвойствоОбъекта(ШапкаДокумента, "Номер") 
				И ЗначениеЗаполнено(ШапкаДокумента.Номер) Тогда
				Если СтруктураПоиска = Неопределено Тогда
					СтруктураПоиска = Новый Структура("Номер", ШапкаДокумента.Номер);
				Иначе
					СтруктураПоиска.Вставить("Номер", ШапкаДокумента.Номер);
				КонецЕсли;
			КонецЕсли;   
						
			Если ГУИДДокумента <> ПустойИдентификатор Тогда
				ДокументСсылка = ПолучитьСсылкуДокумента("КАМИ_СервисныеРаботы", ГУИДДокумента, СтруктураПоиска, Ложь);
				Если ЗначениеЗаполнено(ДокументСсылка) Тогда
					СписокДокументов.Вставить(ДокументСсылка, ДанныеДокумента);
				КонецЕсли;
			Иначе
				МассивДокументов = ПолучитьСсылкиДокументов("КАМИ_СервисныеРаботы", ГУИДДокумента, СтруктураПоиска, Ложь);
				Для Каждого ДокументСсылка Из МассивДокументов Цикл
					СписокДокументов.Вставить(ДокументСсылка, ДанныеДокумента);
				КонецЦикла;
			КонецЕсли;
		КонецЦикла;
	КонецЕсли;

	КАМИ_ОбменДаннымиОбработка = Обработки.КАМИ_ОбменДанными.Создать();	
	СписокТиповСсылок = Новый Соответствие;
	КэшНайденныхСсылок = Новый Соответствие;
	
	ДополнитьМассивСсылокПоМассивуСтруктур(СписокДокументов, СписокТиповСсылок, КэшНайденныхСсылок, КАМИ_ОбменДаннымиОбработка);
	ТабличныеЧасти = Новый Соответствие;
	ТабличныеЧасти.Вставить("Товары", "Товары");
	ТабличныеЧасти.Вставить("РаботыИнженера", "РаботыИнженера");
	ТабличныеЧасти.Вставить("Контакты", "СторонниеЛица");
	ТабличныеЧасти.Вставить("Работники", "РаботникиОрганизации");
	ТабличныеЧасти.Вставить("Выезды", "ВыездыПоТехническомуЗаданию");  
	ТабличныеЧасти.Вставить("СоответствиеТоваровВыездам", "СоответствиеТоваровВыездам");
	
	ТабличныеЧастиПоиск = Новый Соответствие;
	ТабличныеЧастиПоиск.Вставить("Товары", "КлючСвязи");
	ТабличныеЧастиПоиск.Вставить("РаботыИнженера", "КлючСвязи, РаботаИнженера");
	ТабличныеЧастиПоиск.Вставить("Контакты", "КонтактноеЛицо, ТелефонКонтактногоЛица");
	ТабличныеЧастиПоиск.Вставить("Работники", "КлючСвязи, Работник");
	ТабличныеЧастиПоиск.Вставить("Выезды", "КлючСвязи");  
	ТабличныеЧастиПоиск.Вставить("СоответствиеТоваровВыездам", "КлючСвязиТовары, КлючСвязиВыезды");
	
	Для Каждого ДокументЭлемент Из СписокДокументов Цикл  		
		Для Каждого ТЧ Из ТабличныеЧасти Цикл
			Если ДокументЭлемент.Значение.Свойство(ТЧ.Ключ) Тогда 
				ДополнитьМассивСсылокПоМассивуСтруктур(ДокументЭлемент.Значение[ТЧ.Ключ], СписокТиповСсылок, КэшНайденныхСсылок, КАМИ_ОбменДаннымиОбработка);
			КонецЕсли;
		КонецЦикла;	
		//+ КАМИ 20.11.2023 12:15:15 Гросу Р.И. № Дополнить реквизиты шапки
		Для Каждого РеквизитДокумента Из ДокументЭлемент.Значение Цикл
			Если НЕ РеквизитДокумента.Ключ = "ШапкаДокумента" И ТабличныеЧасти.Получить(РеквизитДокумента.Ключ) = Неопределено Тогда
				ДокументЭлемент.Значение.ШапкаДокумента.Вставить(РеквизитДокумента.Ключ, РеквизитДокумента.Значение);
			КонецЕсли;
		КонецЦикла;
		//- КАМИ 20.11.2023 12:15:17 Гросу Р.И. 
	КонецЦикла;
	
	ЗаполнитьКэшНайденныхСсылок(СписокТиповСсылок, КэшНайденныхСсылок, КАМИ_ОбменДаннымиОбработка);
	
	РеквизитыТипДата = Новый Массив;
	РеквизитыТипДата.Добавить("Дата");
	РеквизитыТипДата.Добавить("ДатаОкончания");
	РеквизитыТипДата.Добавить("ДатаГотовностиПредварительная");
	РеквизитыТипДата.Добавить("ДатаНачалаКомандировки");
	РеквизитыТипДата.Добавить("ДатаОкончанияКомандировки");
	РеквизитыТипДата.Добавить("ДатаГотовности");
	
	НовыйМассивДокументов = Новый Массив;
	ПараметрыОтвета = Новый Структура;
	СписокСсылок = Новый Массив;
	Для Каждого ДокументЭлемент Из СписокДокументов Цикл
		СтруктураДокумента = ДокументЭлемент.Значение.ШапкаДокумента; 
		НоваяСтруктураДокумента = СоздатьСтруктуруСтрокиСНайденнымиСсылками(СтруктураДокумента, КэшНайденныхСсылок, КАМИ_ОбменДаннымиОбработка); 
		Для Каждого ТЧ Из ТабличныеЧасти Цикл
			Если ДокументЭлемент.Значение.Свойство(ТЧ.Ключ) Тогда 
				МассивТЧ = Новый Массив;
				Для Каждого Строчка Из ДокументЭлемент.Значение[ТЧ.Ключ] Цикл
					НоваяСтрочкаТЧ = СоздатьСтруктуруСтрокиСНайденнымиСсылками(Строчка, КэшНайденныхСсылок, КАМИ_ОбменДаннымиОбработка); 
					МассивТЧ.Добавить(НоваяСтрочкаТЧ);
				КонецЦикла; 
				НоваяСтруктураДокумента.Вставить(ТЧ.Ключ, МассивТЧ);
			КонецЕсли;
		КонецЦикла;	 
		//+ КАМИ 09.02.2024 15:37:58 Гросу Р.И. №  Контактные лица. Добавим автора
		Если НоваяСтруктураДокумента.Свойство("Контакты") Тогда 
			Для Каждого Строчка Из НоваяСтруктураДокумента.Контакты Цикл
				Строчка.Вставить("Автор", Пользователи.ТекущийПользователь());
			КонецЦикла; 
		КонецЕсли;
		//- КАМИ 09.02.2024 15:38:01 Гросу Р.И. 
		НоваяСтруктураДокумента.Вставить("Ссылка", ДокументЭлемент.Ключ); 
		НовыйМассивДокументов.Добавить(НоваяСтруктураДокумента);
		СписокСсылок.Добавить(ДокументЭлемент.Ключ);
	КонецЦикла;                                   
	
	ИзменитьРеквизитыДокументов(НовыйМассивДокументов, ТабличныеЧасти, ТабличныеЧастиПоиск);
	
	ПараметрыОтвета.Вставить("СписокСсылок", СписокСсылок);
	Возврат ПолучитьСервисныеРаботы(ПараметрыОтвета);
	
КонецФункции
