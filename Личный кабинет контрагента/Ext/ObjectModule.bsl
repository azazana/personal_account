							ДокументОснование = ДокументОснованиеОбъект.Ссылка; 
						КонецЕсли;
					ИначеЕсли СтрНайти(ТипОснования, "Документ.") = 1 Тогда
						ДокументОснование = ПолучитьСсылкуДокумента("ТипОснования", ГУИДОснования, ПоискОснования, Ложь); 
					КонецЕсли;
				КонецЕсли;
				Если ЗначениеЗаполнено(ДокументОснование) Тогда  
					Если СтруктураПоиска = Неопределено Тогда
						СтруктураПоиска = Новый Структура("ДокументОснование", ДокументОснование);
					Иначе
						СтруктураПоиска.Вставить("ДокументОснование", ДокументОснование); 
					КонецЕсли;				
				КонецЕсли;
			КонецЕсли;
			
			Если ГУИДДокумента <> ПустойИдентификатор Тогда
				ДокументСсылка = ПолучитьСсылкуДокумента("КАМИ_СервисныеРаботы", ГУИДДокумента, СтруктураПоиска, Ложь);
