Процедура ОчиститьУстаревшиеСообщения(КоличествоДней = 30) Экспорт
	
	мЗапрос = Новый Запрос;
	мЗапрос.Текст = "ВЫБРАТЬ ПЕРВЫЕ 1500
	|	СообщенияОбмена.ИдентификаторСообщения КАК ИдентификаторСообщения,
	|	СообщенияОбмена.ВидСообщения КАК ВидСообщения,
	|	СообщенияОбмена.ДатаДобавления КАК ДатаДобавления
	|ИЗ
	|	РегистрСведений.КАМИ_ОчередьОбменСервиснаяСлужба КАК СообщенияОбмена
	|ГДЕ
	|	СообщенияОбмена.ДатаДобавления < &ДатаДобавления
	|
	|УПОРЯДОЧИТЬ ПО
	|	ДатаДобавления
	|АВТОУПОРЯДОЧИВАНИЕ";
	
	ДатаДобавления = ТекущаяДата() - 24 * 60 * 60 * КоличествоДней;
	мЗапрос.УстановитьПараметр("ДатаДобавления", ДатаДобавления); 
	
	ВремяНачала = ТекущаяУниверсальнаяДатаВМиллисекундах();
	
    мВыборка = мЗапрос.Выполнить().Выбрать(); 
	КоличествоЗаписей = мВыборка.Количество();
	Пока мВыборка.Следующий() Цикл
		
		НаборЗаписей = РегистрыСведений.КАМИ_ОчередьОбменСервиснаяСлужба.СоздатьНаборЗаписей();
		
		НаборЗаписей.Отбор.ИдентификаторСообщения.Установить(мВыборка.ИдентификаторСообщения);
		НаборЗаписей.Отбор.ВидСообщения.Установить(мВыборка.ВидСообщения);
		
		КАМИ_ОбменДанными.УдалитьКонтрольИзДополнительныхСвойствОбъекта(НаборЗаписей);
		НаборЗаписей.ОбменДанными.Загрузка = Истина;
		
		НаборЗаписей.Записать();
		
	КонецЦикла;
	
	ВремяОкончания = ТекущаяУниверсальнаяДатаВМиллисекундах();
	
	ЗаписьЖурналаРегистрации("Очистка устаревших сообщений для сервисной службы",
									УровеньЖурналаРегистрации.Предупреждение, , ,
									"Количество записей : " + Формат(КоличествоЗаписей,"ЧДЦ=3; ЧН=; ЧГ=0") + Символы.ПС +  
									"Время выполнения " + Формат((ВремяОкончания - ВремяНачала)/1000,"ЧДЦ=3; ЧН=; ЧГ=0")+ " сек");
	
КонецПроцедуры

Функция ПолучитьСписокПланаОбмена(стрИмяПланаОбмена)
	
	ВыбранныйПланОбмена = Метаданные.ПланыОбмена[стрИмяПланаОбмена];
	
	тзПланОбменаСостав = Новый ТаблицаЗначений;
	тзПланОбменаСостав.Колонки.Добавить("ОбъектКонфигурации", , "Объект конфигурации");
	тзПланОбменаСостав.Колонки.Добавить("Регистрация", , "Регистрация");
	
	Состав = ВыбранныйПланОбмена.Состав;
	
	Для каждого Элемент Из Состав Цикл
		
		Стр = тзПланОбменаСостав.Добавить();
		Стр.Регистрация = Элемент.АвтоРегистрация;
		Стр.ОбъектКонфигурации = Элемент.Метаданные.ПолноеИмя();
		
	КонецЦикла;
	
	тзПланОбменаСостав.Сортировать("ОбъектКонфигурации");
	Возврат тзПланОбменаСостав;
	
КонецФункции

Функция СформироватьСообщенияПоИзменениям(ТипСсылки, СписокСсылок)
	
    ПараметрыЗапроса = Новый Структура;
	ПараметрыЗапроса.Вставить("СписокСсылок", СписокСсылок);
	
	Если ТипСсылки = Тип("СправочникСсылка.Номенклатура") Тогда
		Ответ = ОчередьПолучитьРеквизитыНоменклатуры(ПараметрыЗапроса);		
	ИначеЕсли ТипСсылки = Тип("СправочникСсылка.Претензии") Тогда  
		Ответ = ОчередьПолучитьПретензии(ПараметрыЗапроса);
	ИначеЕсли ТипСсылки = Тип("СправочникСсылка.КАМИ_ПаспортаНоменклатуры") Тогда  
		Ответ = ОчередьПолучитьПаспортаНоменклатуры(ПараметрыЗапроса);
	ИначеЕсли ТипСсылки = Тип("ДокументСсылка.КАМИ_ЗаявкаНаШефМонтажныеРаботы") Тогда 
		Ответ = ОчередьПолучитьЗаявкиНаШМР(ПараметрыЗапроса);
	ИначеЕсли ТипСсылки = Тип("ДокументСсылка.КАМИ_СервисныеРаботы") Тогда    
		Ответ = ОчередьПолучитьСервисныеРаботы(ПараметрыЗапроса); 
	//+ КАМИ 08.11.2023 17:39:09 Гросу Р.И. №      
	// ++ КАМИ Леутин 10.06.2024 #0000013867
	ИначеЕсли ТипСсылки = Тип("ДокументСсылка.ЗаявкаНаКомандировку") Тогда
		Ответ = ОчередьПолучитьСервисныеРаботыПоКомандировкам(ПараметрыЗапроса); 
	// -- КАМИ Леутин 10.06.2024 #0000013867
	ИначеЕсли ТипСсылки = Тип("СправочникСсылка.КАМИ_СервисныеРаботыПрисоединенныеФайлы") Тогда 
	    ПараметрыЗапроса.Вставить("ПолучитьФайлы", Истина); 
		ПараметрыЗапроса.Вставить("СписокФайлов", СписокСсылок);
		Ответ = ОчередьПолучитьФайлыСервисныхРабот(ПараметрыЗапроса); 
	//- КАМИ 08.11.2023 17:39:11 Гросу Р.И. 
	ИначеЕсли ТипСсылки = Тип("СправочникСсылка.КАМИ_РаботыИнженера") Тогда    
		Ответ = ОчередьПолучитьРаботыИнженера(ПараметрыЗапроса);  
	ИначеЕсли ТипСсылки = Тип("СправочникСсылка.Пользователи") Тогда 
		СоответствиеПользователей = ОбщегоНазначения.ЗначениеРеквизитаОбъектов(СписокСсылок, "ИдентификаторПользователяИБ");
		СписокПользователей = Новый Массив;
		Для Каждого Строчка Из СоответствиеПользователей Цикл
			СписокПользователей.Добавить(Строчка.Значение);
		КонецЦикла; 
		ПараметрыЗапроса.Вставить("СписокСсылок", СписокПользователей);
		Ответ = ОчередьПолучитьПользователейИБ(ПараметрыЗапроса);
	КонецЕсли;	
		
	Возврат Ответ;
	
КонецФункции

Функция ПолучитьИдентификаторыОчередиПоВидуСообщений(ПараметрыЗапроса) Экспорт
	
	Идентификаторы = Новый Массив;
    ВидСообщенияСсылка = Неопределено;
	СтатусыОтправки = Новый Массив;
	 	
	ОтборПоВидуСообщений = Ложь; 
    КоличествоСообщений = 0;
	
	Если ОбщегоНазначенияКлиентСервер.ЕстьРеквизитИлиСвойствоОбъекта(ПараметрыЗапроса, "ВидСообщения") Тогда
		ВидСообщения = ПараметрыЗапроса.ВидСообщения; 
		Если ЗначениеЗаполнено(ВидСообщения) Тогда
			ВидСообщенияСсылка = Справочники.КАМИ_ВидыСообщенийСервиснаяСлужба.НайтиПоНаименованию(ВидСообщения);
		КонецЕсли;
		ОтборПоВидуСообщений = ЗначениеЗаполнено(ВидСообщенияСсылка);	
	КонецЕсли;
	
	Если ОбщегоНазначенияКлиентСервер.ЕстьРеквизитИлиСвойствоОбъекта(ПараметрыЗапроса, "Количество") Тогда
		Если ЗначениеЗаполнено(ПараметрыЗапроса.Количество) Тогда    
			КоличествоСообщений =  ПараметрыЗапроса.Количество;
		КонецЕсли;
		Если НЕ ЗначениеЗаполнено(КоличествоСообщений) Тогда
			КоличествоСообщений = 0;
		КонецЕсли;
	КонецЕсли;

	Если ОбщегоНазначенияКлиентСервер.ЕстьРеквизитИлиСвойствоОбъекта(ПараметрыЗапроса, "СтатусыОтправки") Тогда
		МассивСтатусов = Новый Массив;
		Если ТипЗнч(ПараметрыЗапроса.СтатусыОтправки) = Тип("Строка") Тогда
			МассивСтатусов = СтрРазделить(ПараметрыЗапроса.Идентификаторы,",", Ложь);
		ИначеЕсли ТипЗнч(ПараметрыЗапроса.СтатусыОтправки) = Тип("Массив") Тогда
			МассивСтатусов = ПараметрыЗапроса.СтатусыОтправки;
		КонецЕсли;		
		Для Каждого СтрокаСтатуса Из МассивСтатусов Цикл
			Если ВРЕГ(СтрокаСтатуса) = ВРЕГ("К отправке") Тогда 
				СтатусыОтправки.Добавить(Перечисления.КАМИ_СтатусыОтправкиОбменСервиснаяСлужба.КОтправке);
			ИначеЕсли ВРЕГ(СтрокаСтатуса) = ВРЕГ("КОтправке") Тогда 
				СтатусыОтправки.Добавить(Перечисления.КАМИ_СтатусыОтправкиОбменСервиснаяСлужба.КОтправке);
			ИначеЕсли ВРЕГ(СтрокаСтатуса) = ВРЕГ("Отправлен") Тогда 
				СтатусыОтправки.Добавить(Перечисления.КАМИ_СтатусыОтправкиОбменСервиснаяСлужба.Отправлен);
			ИначеЕсли ВРЕГ(СтрокаСтатуса) = ВРЕГ("Доставлен") Тогда 
				СтатусыОтправки.Добавить(Перечисления.КАМИ_СтатусыОтправкиОбменСервиснаяСлужба.Доставлен);
			ИначеЕсли ВРЕГ(СтрокаСтатуса) = ВРЕГ("ОшибкаОтправки") Тогда 
				СтатусыОтправки.Добавить(Перечисления.КАМИ_СтатусыОтправкиОбменСервиснаяСлужба.ОшибкаОтправки);
			ИначеЕсли ВРЕГ(СтрокаСтатуса) = ВРЕГ("Ошибка отправки") Тогда 
				СтатусыОтправки.Добавить(Перечисления.КАМИ_СтатусыОтправкиОбменСервиснаяСлужба.ОшибкаОтправки);
			ИначеЕсли ВРЕГ(СтрокаСтатуса) = ВРЕГ("ОшибкаДоставки") Тогда 
				СтатусыОтправки.Добавить(Перечисления.КАМИ_СтатусыОтправкиОбменСервиснаяСлужба.ОшибкаДоставки);
			ИначеЕсли ВРЕГ(СтрокаСтатуса) = ВРЕГ("Ошибка доставки") Тогда 
				СтатусыОтправки.Добавить(Перечисления.КАМИ_СтатусыОтправкиОбменСервиснаяСлужба.ОшибкаДоставки);
			КонецЕсли;                                                                                    			
		КонецЦикла;
	КонецЕсли;

	Если СтатусыОтправки.Количество() = 0 Тогда
		СтатусыОтправки.Добавить(Перечисления.КАМИ_СтатусыОтправкиОбменСервиснаяСлужба.КОтправке);
	КонецЕсли;	
	
	мЗапрос = Новый Запрос;
	мЗапрос.Текст = "ВЫБРАТЬ
	|	СообщенияОбмена.ИдентификаторСообщения КАК Идентификатор,
	|	СообщенияОбмена.ВидСообщения.Наименование КАК ВидСообщенияНаименование,
	|	СообщенияОбмена.ВидСообщения КАК ВидСообщения,
	|	СообщенияОбмена.СодержимоеСообщения КАК СодержимоеСообщения,
	|	ПРЕДСТАВЛЕНИЕ(СообщенияОбмена.СтатусОтправки) КАК СтатусОтправкиНаименование,
	|	СообщенияОбмена.СтатусОтправки КАК СтатусОтправки,
	|	СообщенияОбмена.ДатаДобавления КАК ДатаДобавления,
	|	СообщенияОбмена.ДатаДобавленияМиллисекунды КАК ДатаДобавленияМиллисекунды,
	|	СообщенияОбмена.ОписаниеОшибки КАК ОписаниеОшибки,
	|	СообщенияОбмена.ДатаОтправки КАК ДатаОтправки
	|ИЗ
	|	РегистрСведений.КАМИ_ОчередьОбменСервиснаяСлужба КАК СообщенияОбмена
	|ГДЕ
	|	ВЫБОР
	|			КОГДА &ОтборПоВидуСообщений = ИСТИНА
	|				ТОГДА СообщенияОбмена.ВидСообщения = &ВидСообщения
	|			ИНАЧЕ ИСТИНА
	|		КОНЕЦ
	|	И СообщенияОбмена.СтатусОтправки В(&СтатусыОтправки)
	|
	|УПОРЯДОЧИТЬ ПО
	|	ДатаДобавления,
	|	ДатаДобавленияМиллисекунды
	|АВТОУПОРЯДОЧИВАНИЕ";
	мЗапрос.УстановитьПараметр("ОтборПоВидуСообщений", ОтборПоВидуСообщений);
	мЗапрос.УстановитьПараметр("ВидСообщения", ВидСообщенияСсылка);
	мЗапрос.УстановитьПараметр("СтатусыОтправки", СтатусыОтправки);

	Если ЗначениеЗаполнено(КоличествоСообщений) Тогда
		мЗапрос.Текст = СтрЗаменить(мЗапрос.Текст, "ВЫБРАТЬ", "ВЫБРАТЬ ПЕРВЫЕ " + Формат(КоличествоСообщений, "ЧДЦ=0"));
	КонецЕсли;
	
	мВыборка = мЗапрос.Выполнить().Выбрать();
	МассивСообщений = Новый Массив;
	ОтправленныеИдентификаторы = Новый Массив;
	Пока мВыборка.Следующий() Цикл
		СтруктураСообщения = Новый Структура("Идентификатор, ДатаДобавления");
		ЗаполнитьЗначенияСвойств(СтруктураСообщения, мВыборка);
		//СтрокаСообщения = мВыборка.СодержимоеСообщения.Получить();
		//СодержимоеСообщения = СтруктураИзСтрокиJSON(СтрокаСообщения); 
		//СтруктураСообщения.Вставить("Сообщение", СодержимоеСообщения);
		//СтруктураСообщения.Вставить("СтатусОтправки", мВыборка.СтатусОтправкиНаименование);                                                                            
		СтруктураСообщения.Вставить("ВидСообщения", мВыборка.ВидСообщенияНаименование);
		МассивСообщений.Добавить(СтруктураСообщения);  
		ОтправленныеИдентификаторы.Добавить(мВыборка.Идентификатор);
	КонецЦикла;
	
	//ИзменитьСтатусыСообщений(ОтправленныеИдентификаторы, Перечисления.КАМИ_СтатусыОтправкиОбменСервиснаяСлужба.Отправлен);
	
	Ответ = Новый Структура;
	
	Ответ.Вставить("РезультатЗапроса", МассивСообщений);
	Ответ.Вставить("ТекстОшибки","");
	Ответ.Вставить("СтатусОтвета",200);
	
	Возврат Ответ;

