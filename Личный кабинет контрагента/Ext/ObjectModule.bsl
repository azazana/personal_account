Функция ПолучитьИдентификаторСБИС(тЗаявкаНаКомандировку)

	Запрос = Новый Запрос;
	Запрос.Текст = "ВЫБРАТЬ
	               |	КАМИ_ИдентификаторыСБИСДокументов.ИдентификаторСБИС КАК ИдентификаторСБИС
	               |ИЗ
	               |	РегистрСведений.КАМИ_ИдентификаторыСБИСДокументов КАК КАМИ_ИдентификаторыСБИСДокументов
	               |ГДЕ
	               |	КАМИ_ИдентификаторыСБИСДокументов.Документ = &Документ";
	
	Запрос.УстановитьПараметр("Документ", тЗаявкаНаКомандировку);
	РезЗапроса = Запрос.Выполнить();
	Если РезЗапроса.Пустой() Тогда
		Возврат неопределено;	
	КонецЕсли;	
	
	Выборка = РезЗапроса.Выбрать();
	Выборка.Следующий();
	
	Возврат Выборка.ИдентификаторСБИС;

КонецФункции
