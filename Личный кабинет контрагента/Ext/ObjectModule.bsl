Функция ПолучитьТаблицуЖурналДокументов(ПараметрыЗапроса) Экспорт
	
	СписокКлиентов = Новый Массив;
	Если ОбщегоНазначенияКлиентСервер.ЕстьРеквизитИлиСвойствоОбъекта(ПараметрыЗапроса, "СписокКлиентов") Тогда
		Для Каждого ДанныеКлиента Из ПараметрыЗапроса.СписокКлиентов Цикл
			ГУИДКлиента = ДанныеКлиента.GUID;                                                  
			СтруктураПоиска = Новый Структура;
			Если ОбщегоНазначенияКлиентСервер.ЕстьРеквизитИлиСвойствоОбъекта(ДанныеКлиента, "Код") Тогда
				СтруктураПоиска.Вставить("Код", ДанныеКлиента.Код);
			КонецЕсли;
			КлиентОбъект = ПолучитьОбъектОбработкиСправочник("Партнеры", ГУИДКлиента, СтруктураПоиска, Ложь);
			Если НЕ КлиентОбъект.ЭтоНовый() Тогда
				СписокКлиентов.Добавить(КлиентОбъект.Ссылка);
			Иначе
				КлиентОбъект = ПолучитьОбъектОбработкиСправочник("CRM_ПотенциальныеКлиенты", ГУИДКлиента, СтруктураПоиска, Ложь);
				Если НЕ КлиентОбъект.ЭтоНовый() Тогда
					СписокКлиентов.Добавить(КлиентОбъект.Ссылка); 
				КонецЕсли;
			КонецЕсли;
		КонецЦикла;
	КонецЕсли;

	Если ОбщегоНазначенияКлиентСервер.ЕстьРеквизитИлиСвойствоОбъекта(ПараметрыЗапроса, "СписокСсылок") Тогда
		Для Каждого ДанныеСсылки Из ПараметрыЗапроса.СписокСсылок Цикл		
			СписокКлиентов.Добавить(ДанныеСсылки);
		КонецЦикла;
	КонецЕсли;

	Если СписокКлиентов.Количество() = 0 Тогда		
		СписокКлиентов.Добавить(Справочники.Партнеры.ПустаяСсылка()); 
	КонецЕсли;  
	
	мОбъектЗапроса = Новый Запрос;
	мОбъектЗапроса.Текст = ТекстЗапросаЖурналДокументов();	
	мОбъектЗапроса.УстановитьПараметр("СписокКлиентов", СписокКлиентов);
	
	ТаблицаРезультат = мОбъектЗапроса.Выполнить().Выгрузить();      

	ЗаполнитьКэшСсылокПоТаблицеЗначений(ТаблицаРезультат);

	Возврат ТаблицаРезультат;
	
КонецФункции
