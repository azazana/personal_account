Функция ПолучитьСписокПечатныхФорм(ПараметрыЗапроса) Экспорт
	
	Результат = "";
	
	ТипЗначенияСсылки = "";
	Если ОбщегоНазначенияКлиентСервер.ЕстьРеквизитИлиСвойствоОбъекта(ПараметрыЗапроса, "ТипЗначения") Тогда
		ТипЗначенияСсылки = ПараметрыЗапроса.ТипЗначения;	
	КонецЕсли;
	
	Если ЗначениеЗаполнено(ТипЗначенияСсылки) Тогда
		ТипСсылки = СтрЗаменить(ТипЗначенияСсылки, "Документ.", "");
		МетаданныеСсылки = Метаданные.Документы.Найти(ТипСсылки);
		Если МетаданныеСсылки = Неопределено Тогда
			ТипСсылки = СтрЗаменить(ТипЗначенияСсылки, "Справочник.", "");
			МетаданныеСсылки = Метаданные.Справочники.Найти(ТипСсылки); 
		КонецЕсли;
		
		Если МетаданныеСсылки = Неопределено Тогда
			Возврат "";
		КонецЕсли;
		
		КомандыПечати = УправлениеПечатью.КомандыПечатиОбъектаДоступныеДляВложений(МетаданныеСсылки);
		Если Ложь Тогда
			КомандыПечати = Новый ТаблицаЗначений;
		КонецЕсли;
		
		КомандыПечати.Свернуть("Идентификатор, Представление");
		КомандыПечати.Сортировать("Представление");
		
		Результат = ОбщегоНазначения.ТаблицаЗначенийВМассив(КомандыПечати);
		
	КонецЕсли; 
	
	Ответ = Новый Структура;
	
	Ответ.Вставить("РезультатЗапроса", Результат);
	Ответ.Вставить("ТекстОшибки","");
	Ответ.Вставить("СтатусОтвета",200);
	
	Возврат Ответ;
	
КонецФункции
