Функция ПолучитьОписанияФайлов(МассивСсылок, ВключаяПомеченныеНаУдаление = Ложь, ПолучатьДвоичныеДанные = Ложь) Экспорт
	
	Если ТипЗнч(МассивСсылок) <> Тип("Массив") Тогда
		Возврат Неопределено;
	КонецЕсли;   
	
	ПрикрепленныеФайлы = ПолучитьПрикрепленныеКСсылкамФайлы(МассивСсылок, ВключаяПомеченныеНаУдаление);
	Если ПрикрепленныеФайлы = Неопределено Тогда
		Возврат Неопределено;
	КонецЕсли;
	
	ПараметрыДанныхФайла = РаботаСФайламиКлиентСервер.ПараметрыДанныхФайла();
	ПараметрыДанныхФайла.ИдентификаторФормы 			= Новый УникальныйИдентификатор;
	ПараметрыДанныхФайла.ВызыватьИсключение 			= Ложь;    
	ПараметрыДанныхФайла.ПолучатьСсылкуНаДвоичныеДанные = ПолучатьДвоичныеДанные;
	
	Результат = Новый Соответствие;
	
	Для Каждого СписокФайлов Из ПрикрепленныеФайлы Цикл
		МассивДанныхФайлов = Новый Массив;
		Для Каждого Файл Из СписокФайлов.Значение Цикл  
			ДанныеФайла = РаботаСФайлами.ДанныеФайла(Файл, ПараметрыДанныхФайла);
			СвойстваВТоме = РаботаСФайламиВТомахСлужебный.СвойстваФайлаВТоме(Файл);
			ПутьКФайлу = "";
			СвойстваВТоме.Свойство("ПутьКФайлу", ПутьКФайлу);
			ДанныеФайла.Вставить("ПутьКФайлу", ПутьКФайлу);
			МассивДанныхФайлов.Добавить(ДанныеФайла);
		КонецЦикла;
		Если МассивДанныхФайлов.Количество() Тогда
			Результат.Вставить(СписокФайлов.Ключ, МассивДанныхФайлов);
		КонецЕсли;
	КонецЦикла;       
	
	Возврат Результат;
	
