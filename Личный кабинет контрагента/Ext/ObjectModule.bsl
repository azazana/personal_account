Функция СформироватьСообщениеДляОбмена(ВидСообщения, ТаблицаСообщений, ЗаполнятьКэш = Ложь) Экспорт
	
	Если КэшВидовСообщений = Неопределено Тогда
		КэшВидовСообщений = Новый Соответствие;
	КонецЕсли;
	
	Если ТипЗнч(ВидСообщения) = Тип("Строка") Тогда 
		ВидСообщенияСсылка = КэшВидовСообщений.Получить(ВидСообщения);
		Если ВидСообщенияСсылка = Неопределено Тогда
			ВидСообщенияСсылка = Справочники.КАМИ_ВидыСообщенийСервиснаяСлужба.НайтиПоНаименованию(ВидСообщения);
			Если НЕ ЗначениеЗаполнено(ВидСообщенияСсылка) Тогда                                     
				Если НЕ ЗначениеЗаполнено(ВидСообщения) Тогда
					Возврат Неопределено;
				КонецЕсли;
				
				ВидСообщенияОбъект = Справочники.КАМИ_ВидыСообщенийСервиснаяСлужба.СоздатьЭлемент();
				ВидСообщенияОбъект.Наименование = ВидСообщения;
				ВидСообщенияОбъект.Записать();
				ВидСообщенияСсылка = ВидСообщенияОбъект.Ссылка;
			КонецЕсли;                                  
		КонецЕсли;
		КэшВидовСообщений.Вставить(ВидСообщения, ВидСообщенияСсылка);
	ИначеЕсли ТипЗнч(ВидСообщения) = Тип("СправочникСсылка.КАМИ_ВидыСообщенийСервиснаяСлужба") Тогда
		ВидСообщенияСсылка = ВидСообщения;
	Иначе
		Возврат Неопределено;
	КонецЕсли;
	
	Если ЗаполнятьКэш = Истина Тогда
		ЗаполнитьКэшСсылокПоТаблицеЗначений(ТаблицаСообщений);
	КонецЕсли; 
	
	РезультатЗапроса = ЗаполнитьТаблицуЗначенийПоКэшуСсылок(ТаблицаСообщений);
	
	СтрокаСообщения = УпаковатьОтветВJSON(РезультатЗапроса);
	
	ИдентификаторСообщения = XMLСтрока(Новый УникальныйИдентификатор);
	НаборЗаписей = РегистрыСведений.КАМИ_ОчередьОбменСервиснаяСлужба.СоздатьНаборЗаписей();
	НаборЗаписей.Отбор.ИдентификаторСообщения.Установить(ИдентификаторСообщения);
	НаборЗаписей.Отбор.ВидСообщения.Установить(ВидСообщенияСсылка);
	
	ДатаДобавленияУниверсальная = ТекущаяУниверсальнаяДатаВМиллисекундах();
	ДатаДобавления = Дата(1,1,1) + ДатаДобавленияУниверсальная/1000 + СмещениеСтандартногоВремени(ЧасовойПояс(),) + СмещениеЛетнегоВремени(ЧасовойПояс(),);
	ДатаДобавленияМиллисекунды = ДатаДобавленияУниверсальная % 1000;
	
	НоваяЗапись = НаборЗаписей.Добавить();
	НоваяЗапись.ИдентификаторСообщения = ИдентификаторСообщения;
	НоваяЗапись.ВидСообщения = ВидСообщенияСсылка;
	НоваяЗапись.СтатусОтправки = Перечисления.КАМИ_СтатусыОтправкиОбменСервиснаяСлужба.КОтправке;
	НоваяЗапись.ДатаДобавления = ДатаДобавления;
	НоваяЗапись.ДатаДобавленияМиллисекунды = ДатаДобавленияМиллисекунды;
	НоваяЗапись.СодержимоеСообщения = Новый ХранилищеЗначения(СтрокаСообщения, Новый СжатиеДанных(9));
	
	НаборЗаписей.ДополнительныеСвойства.Вставить("ОтключитьМеханизмРегистрацииОбъектов", Истина);
	НаборЗаписей.ДополнительныеСвойства.Вставить("НеПроверятьДатыЗапретаИзмененияДанных", Истина);
	НаборЗаписей.ДополнительныеСвойства.Вставить("НеВыполнятьКонтрольУдаляемых");
	НаборЗаписей.ДополнительныеСвойства.Вставить("ПропуститьПроверкуСогласованности");
	НаборЗаписей.ДополнительныеСвойства.Вставить("Ками_загрузка", Истина);
	НаборЗаписей.ДополнительныеСвойства.Вставить("Ками_ИгнорироватьПроверки");
	
	НаборЗаписей.Записать();
	
	Возврат ИдентификаторСообщения;
	
КонецФункции

Функция СформироватьСообщенияДляОбмена(ВидСообщения, ТаблицаСообщений, КоличествоЗаписей = 0) Экспорт
	
	Если КэшВидовСообщений = Неопределено Тогда
		КэшВидовСообщений = Новый Соответствие;
	КонецЕсли;

	Если ТипЗнч(ВидСообщения) = Тип("Строка") Тогда 
		ВидСообщенияСсылка = КэшВидовСообщений.Получить(ВидСообщения);
		Если ВидСообщенияСсылка = Неопределено Тогда
			ВидСообщенияСсылка = Справочники.КАМИ_ВидыСообщенийСервиснаяСлужба.НайтиПоНаименованию(ВидСообщения);
			Если НЕ ЗначениеЗаполнено(ВидСообщенияСсылка) Тогда                                     
				Если НЕ ЗначениеЗаполнено(ВидСообщения) Тогда
					Возврат Неопределено;
				КонецЕсли;
				
				ВидСообщенияОбъект = Справочники.КАМИ_ВидыСообщенийСервиснаяСлужба.СоздатьЭлемент();
				ВидСообщенияОбъект.Наименование = ВидСообщения;
				ВидСообщенияОбъект.Записать();
				ВидСообщенияСсылка = ВидСообщенияОбъект.Ссылка;
			КонецЕсли;                                  
		КонецЕсли;
		КэшВидовСообщений.Вставить(ВидСообщения, ВидСообщенияСсылка);
	ИначеЕсли ТипЗнч(ВидСообщения) = Тип("СправочникСсылка.КАМИ_ВидыСообщенийСервиснаяСлужба") Тогда
		ВидСообщенияСсылка = ВидСообщения;
	Иначе
		Возврат Неопределено;
	КонецЕсли;
	
	Если Ложь Тогда
		ТаблицаСообщений = Новый ТаблицаЗначений;
	КонецЕсли;
	
	СписокСообщений = Новый Массив;
	
	Если КоличествоЗаписей <= 0 Тогда
		ИдентификаторСообщения = СформироватьСообщениеДляОбмена(ВидСообщенияСсылка, ТаблицаСообщений); 
		Если ЗначениеЗаполнено(ИдентификаторСообщения) Тогда
			СписокСообщений.Добавить(ИдентификаторСообщения);
		КонецЕсли;	
		Возврат СписокСообщений;
	КонецЕсли;
	
	МассивСтрок = Новый Массив;  
	
	Для Каждого Строчка Из ТаблицаСообщений Цикл
		Если МассивСтрок.Количество() > КоличествоЗаписей Тогда
			НоваяТаблица = ТаблицаСообщений.Скопировать(МассивСтрок);
			ИдентификаторСообщения = СформироватьСообщениеДляОбмена(ВидСообщенияСсылка, НоваяТаблица);  
			Если ЗначениеЗаполнено(ИдентификаторСообщения) Тогда
				СписокСообщений.Добавить(ИдентификаторСообщения);
			КонецЕсли;
			
			МассивСтрок = Новый Массив;
		КонецЕсли;
		МассивСтрок.Добавить(Строчка);
	КонецЦикла;
	Если МассивСтрок.Количество() Тогда
		НоваяТаблица = ТаблицаСообщений.Скопировать(МассивСтрок);
		ИдентификаторСообщения = СформироватьСообщениеДляОбмена(ВидСообщенияСсылка, НоваяТаблица);
		Если ЗначениеЗаполнено(ИдентификаторСообщения) Тогда
			СписокСообщений.Добавить(ИдентификаторСообщения);
		КонецЕсли;
	КонецЕсли;
	
	Возврат СписокСообщений;
	
КонецФункции

Функция ПолучитьРезультатФормированияОчередиСообщений(ПараметрыЗапроса, ВидСообщений) Экспорт
	
	Если НЕ ЗначениеЗаполнено(ВидСообщений) Тогда
		ДанныеОтвета = новый Структура;
		ДанныеОтвета.Вставить("ТекстОшибки","Не задан вид сообщений");    
		ДанныеОтвета.Вставить("ПараметрыЗапроса",ПараметрыЗапроса);
		ДанныеОтвета.Вставить("СтатусОтвета",400);
		Возврат ДанныеОтвета;
	КонецЕсли;
	
	КоличествоЗаписей = 10;
	ТаблицаРезультат = Новый ТаблицаЗначений;
	
	НазваниеФункции = ФункцияПолучениеТаблицыРезультата(ВидСообщений); 
	Попытка
		Выполнить("ТаблицаРезультат = " + НазваниеФункции + " (ПараметрыЗапроса)");
	Исключение
		ОписаниеОшибки = ПодробноеПредставлениеОшибки(ИнформацияОбОшибке());
	    ДанныеОтвета = новый Структура;
		ДанныеОтвета.Вставить("ТекстОшибки",ОписаниеОшибки);    
		ДанныеОтвета.Вставить("ПараметрыЗапроса",ПараметрыЗапроса);
		ДанныеОтвета.Вставить("СтатусОтвета",400);
		Возврат ДанныеОтвета;
	КонецПопытки;
	
	СписокСообщений = СформироватьСообщенияДляОбмена(ВидСообщений, ТаблицаРезультат, КоличествоЗаписей); 
	
	Если НЕ СписокСообщений = Неопределено Тогда 
		РезультатЗапроса = Новый Структура("ВидСообщения, КоличествоСообщений, Идентификаторы", ВидСообщений, СписокСообщений.Количество(), СписокСообщений);
	Иначе
		РезультатЗапроса = Новый Структура("ВидСообщения, КоличествоСообщений, Идентификаторы", ВидСообщений, 0, Новый Массив);
	КонецЕсли;
	
	Ответ = Новый Структура;
	
	Ответ.Вставить("РезультатЗапроса", РезультатЗапроса);
	Ответ.Вставить("ТекстОшибки","");
	Ответ.Вставить("СтатусОтвета",200);
	
	Возврат Ответ;

КонецФункции

