//+ КАМИ 04.10.2024 18:22:04 Гросу Р.И. № 0000033652
Функция ПолучитьТаблицуQRКодВозвратДС(ПараметрыЗапроса) Экспорт
	
    //СписокДокументов 		= ПолучитьСписокДокументовИзПараметровЗапроса(ПараметрыЗапроса, "СписаниеБезналичныхДенежныхСредств");
	
	СписокДокументов = Новый Соответствие;

	Если ОбщегоНазначенияКлиентСервер.ЕстьРеквизитИлиСвойствоОбъекта(ПараметрыЗапроса, "СписокДокументов") Тогда
		Для Каждого ДанныеДокумента Из ПараметрыЗапроса.СписокДокументов Цикл 
			Если ОбщегоНазначенияКлиентСервер.ЕстьРеквизитИлиСвойствоОбъекта(ДанныеДокумента, "GUID") Тогда
				ГУИДДокумента = ДанныеДокумента.GUID;                                                  
			ИначеЕсли ОбщегоНазначенияКлиентСервер.ЕстьРеквизитИлиСвойствоОбъекта(ДанныеДокумента, "Ссылка") Тогда
				ГУИДДокумента = ДанныеДокумента.Ссылка;
			Иначе
				ГУИДДокумента = ПустойИдентификатор;
			КонецЕсли;   
			
			СтруктураПоиска = Неопределено;
			Если ОбщегоНазначенияКлиентСервер.ЕстьРеквизитИлиСвойствоОбъекта(ДанныеДокумента, "Дата") 
				И ЗначениеЗаполнено(ДанныеДокумента.Дата) Тогда
				СтруктураПоиска = Новый Структура("Дата", ДанныеДокумента.Дата);
			КонецЕсли;
			Если ОбщегоНазначенияКлиентСервер.ЕстьРеквизитИлиСвойствоОбъекта(ДанныеДокумента, "Номер") 
				И ЗначениеЗаполнено(ДанныеДокумента.Номер) Тогда
				Если СтруктураПоиска = Неопределено Тогда
					СтруктураПоиска = Новый Структура("Номер", ДанныеДокумента.Номер);
				Иначе
					СтруктураПоиска.Вставить("Номер", ДанныеДокумента.Номер);
				КонецЕсли;
			КонецЕсли;
			ДокументСсылка = ПолучитьСсылкуДокумента("СписаниеБезналичныхДенежныхСредств", ГУИДДокумента, СтруктураПоиска, Ложь);
			СуммаПлатежа = 0;
			Если ОбщегоНазначенияКлиентСервер.ЕстьРеквизитИлиСвойствоОбъекта(ДанныеДокумента, "СуммаПлатежа") 
				И ЗначениеЗаполнено(ДанныеДокумента.СуммаПлатежа) Тогда
				СуммаПлатежа = ДанныеДокумента.СуммаПлатежа;
			КонецЕсли;

			Если ЗначениеЗаполнено(ДокументСсылка) Тогда
				СписокДокументов.Вставить(ДокументСсылка, СуммаПлатежа);
			КонецЕсли;
		КонецЦикла;
	КонецЕсли;
		
	
	Если ОбщегоНазначенияКлиентСервер.ЕстьРеквизитИлиСвойствоОбъекта(ПараметрыЗапроса, "СписокСсылок") Тогда
		Для Каждого ДанныеСсылки Из ПараметрыЗапроса.СписокСсылок Цикл		
			СписокДокументов.Добавить(ДанныеСсылки);
		КонецЦикла;
	КонецЕсли;
	
	ПолучитьПДФ = Ложь;
	Если ОбщегоНазначенияКлиентСервер.ЕстьРеквизитИлиСвойствоОбъекта(ПараметрыЗапроса, "ПолучитьPDF") Тогда 
		ПолучитьПДФ = Истина;
	КонецЕсли;

	СуммаПлатежа = 0;
	Если ОбщегоНазначенияКлиентСервер.ЕстьРеквизитИлиСвойствоОбъекта(ПараметрыЗапроса, "СуммаПлатежа") Тогда 
		СуммаПлатежа = ПараметрыЗапроса.СуммаПлатежа;
	КонецЕсли;
	
	ТаблицаРезультата = Новый ТаблицаЗначений; 
	ТаблицаРезультата.Колонки.Добавить("Ссылка");
	ТаблицаРезультата.Колонки.Добавить("ДанныеПлатежа");
	Если ПолучитьПДФ = Истина Тогда
		ТаблицаРезультата.Колонки.Добавить("PDF");
	КонецЕсли;
	
	Для Каждого Строчка Из СписокДокументов Цикл    
		
		НоваяСтрочка = ТаблицаРезультата.Добавить();
		НоваяСтрочка.Ссылка = Строчка.Ключ; 
		СуммаПлатежаПоДокументу = СуммаПлатежа;
		Если ЗначениеЗаполнено(Строчка.Значение) Тогда
			СуммаПлатежаПоДокументу = Строчка.Значение;
		КонецЕсли;
		
		НоваяСтрочка.ДанныеПлатежа = Структура_QRКодВозвратДС(Строчка.Ключ, СуммаПлатежаПоДокументу); 
		Если ПолучитьПДФ = Истина Тогда
			ТабДокумент = ПФ_QRКодВозвратДС(Строчка.Ключ, СуммаПлатежаПоДокументу);
			ДвоичныеДанныеPDF = ПолучитьФайлТабличногоДокумента(ТабДокумент, "pdf");
			НоваяСтрочка.PDF = ДвоичныеДанныеPDF;
		КонецЕсли;
		
	КонецЦикла;
	
	Возврат ТаблицаРезультата;
	
КонецФункции
