Функция ДобавитьВложенныеФайлы(ПараметрыЗапроса) Экспорт
	
	///// Массив структур вида:
	/// Владелец - ссылка на владельца файлов
	/// ОписаниеВладельца - структура с описанием ссылки на владельца
	/// Файлы - массив структур с описаниями файлов
	СписокСсылок = РаспознатьСсылкиИДобавитьОписаниеФайлов(ПараметрыЗапроса);
		
	/////////////////////////////////////////////////////////////////////////////////////
	//// Проверка на существование файлов
	МассивСсылок = Новый Массив;
	Для Каждого ДанныеВладельца Из СписокСсылок Цикл                        
		МассивСсылок.Добавить(ДанныеВладельца.Владелец);
	КонецЦикла;
	/////// Соответствие - ключ это ссылка на владельца, значение список описаний присоединенных файлов
	ОписанияФайлов = ПолучитьОписанияФайлов(МассивСсылок, Истина, Ложь);
	////////////////////////////////////////////////
	
	ДобавленныеВладельцы = Новый Соответствие;

	ЗапросТиповФайлов = Новый Запрос("ВЫБРАТЬ
		                      |	Ками_ТипыПрикрепляемыхФайлов.Ссылка КАК Ссылка,
		                      |	Ками_ТипыПрикрепляемыхФайлов.Наименование КАК Наименование,
		                      |	Ками_ТипыПрикрепляемыхФайлов.ОбъектМетаданных КАК ОбъектМетаданных
		                      |ИЗ
		                      |	Справочник.КАМИ_ТипыПрикрепляемыхФайлов КАК Ками_ТипыПрикрепляемыхФайлов");
	
	ТаблицаТиповФайлов = ЗапросТиповФайлов.Выполнить().Выгрузить();
	ТаблицаТиповФайлов.Индексы.Добавить("ОбъектМетаданных, Наименование");
	
	Для Каждого ДанныеВладельца Из СписокСсылок Цикл 
		
		СуществующиеФайлы = ОписанияФайлов.Получить(ДанныеВладельца.Владелец);
		
		Для Каждого ОписаниеФайла Из ДанныеВладельца.Файлы Цикл
			
			Если РаботаСФайламиСлужебный.ПроверитьРасширениеФайлаДляЗагрузки(ОписаниеФайла.Расширение, Ложь) = Ложь Тогда
				Продолжить;
			КонецЕсли;
			
			ДобавлятьФайл = Истина;		
			Если СуществующиеФайлы <> Неопределено Тогда
				///Проверим на уже существующий файл, прикрепленный к владельцу
				Для Каждого ПрисоединенныйФайл Из СуществующиеФайлы Цикл
					Если ПрисоединенныйФайл.Наименование = ОписаниеФайла.Наименование
						И ПрисоединенныйФайл.Расширение = ОписаниеФайла.Расширение Тогда
						ДобавлятьФайл = Ложь;
						Прервать;
					КонецЕсли;
				КонецЦикла;
			КонецЕсли;
			
			Если ОписаниеФайла.Свойство("Данные") И ДобавлятьФайл Тогда
				
				ДвоичныеДанные = Base64Значение(ОписаниеФайла.Данные);
				ВременноеХранилище = ПоместитьВоВременноеХранилище(ДвоичныеДанные);
				
				ПараметрыФайла = РаботаСФайлами.ПараметрыДобавленияФайла();
				ПараметрыФайла.Автор 				= Пользователи.ТекущийПользователь();
				ПараметрыФайла.ВладелецФайлов 		= ДанныеВладельца.Владелец;
				ПараметрыФайла.ИмяБезРасширения 	= ОписаниеФайла.Наименование;
				ПараметрыФайла.РасширениеБезТочки 	= ОписаниеФайла.Расширение;
				
				НовыйФайл = РаботаСФайлами.ДобавитьФайл(ПараметрыФайла, ВременноеХранилище);
				
				Если ЗначениеЗаполнено(НовыйФайл) И ЗначениеЗаполнено(ОписаниеФайла.ТипФайла) Тогда 
					ОбъектМетаданных = СтрЗаменить(ДанныеВладельца.ОписаниеВладельца.ТипЗначения, "Документ.","");
					ОбъектМетаданных = СтрЗаменить(ОбъектМетаданных, "Справочник.","");
					НайденныеТипы = ТаблицаТиповФайлов.НайтиСтроки(Новый Структура("ОбъектМетаданных, Наименование", ОбъектМетаданных, СокрЛП(ОписаниеФайла.ТипФайла)));
					Если НайденныеТипы.Количество() > 0 Тогда 
						ДобавитьТипПрикрепленногоФайла(НовыйФайл, НайденныеТипы[0].Ссылка);
					КонецЕсли;
				КонецЕсли;
				
				ДобавленныеВладельцы.Вставить(ДанныеВладельца.Владелец);
				
			КонецЕсли;
		КонецЦикла;
	КонецЦикла;

	МассивДобавленныхСсылок = ОбщегоНазначения.ВыгрузитьКолонку(ДобавленныеВладельцы, "Ключ", Истина);
	
	ТаблицаРезультата = ПолучитьМассивОписанийФайлов(МассивДобавленныхСсылок, Истина, Ложь);
	
	Ответ = Новый Структура;
	
	Ответ.Вставить("РезультатЗапроса", ТаблицаРезультата);
	Ответ.Вставить("ТекстОшибки","");
	Ответ.Вставить("СтатусОтвета",200);
	
	Возврат Ответ;
	
КонецФункции
