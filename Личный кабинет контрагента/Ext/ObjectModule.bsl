Функция ПолучитьТаблицуОтчетПоКомандировочнымРасходам(ПараметрыЗапроса) Экспорт
	
	СписокОрганизаций = ПолучитьСписокСсылокСправочникаИзПараметровЗапроса(ПараметрыЗапроса, "Организации", "Организации");
	
    СписокКомандировок 		= ПолучитьСписокДокументовИзПараметровЗапроса(ПараметрыЗапроса, "ЗаявкаНаКомандировку");
    СписокСервисныхРабот 	= ПолучитьСписокДокументовИзПараметровЗапроса(ПараметрыЗапроса, "КАМИ_СервисныеРаботы");
	//////////////// Сотрудники, по которым получаем отчет   /////////////////
	СписокПользователей = Новый Массив;
	Если ОбщегоНазначенияКлиентСервер.ЕстьРеквизитИлиСвойствоОбъекта(ПараметрыЗапроса, "СписокСотрудников") Тогда
		Для Каждого ДанныеПользователя Из ПараметрыЗапроса.СписокСотрудников Цикл
			ГУИДПользователя = ДанныеПользователя.GUID;
			Если ЗначениеЗаполнено(ГУИДПользователя)
				И НЕ ГУИДПользователя = ПустойИдентификатор Тогда
				ПользовательИД = Новый УникальныйИдентификатор(ГУИДПользователя);
				СписокПользователей.Добавить(ПользовательИД);
			КонецЕсли;
		КонецЦикла;
	КонецЕсли;
	
	Если СписокПользователей.Количество() Тогда
		мОбъектЗапроса = Новый Запрос;
		мОбъектЗапроса.Текст = ТекстЗапросаПользователиИБ();
		
		мОбъектЗапроса.УстановитьПараметр("СписокПользователей", СписокПользователей);
		мОбъектЗапроса.УстановитьПараметр("ОтборПользователей", Истина);        
		
		ТаблицаПользователей = мОбъектЗапроса.Выполнить().Выгрузить();      
		
		СписокСотрудников = ТаблицаПользователей.Скопировать(,"ФизическоеЛицо").ВыгрузитьКолонку("ФизическоеЛицо");
	Иначе
		СписокСотрудников = Новый Массив;
	КонецЕсли;
	//////////////////////////////////////////////////////////////	
	
	НачалоПериода 	= Дата(1,1,1);
	КонецПериода	= ТекущаяДата();		
	ПолучитьПериодИзПараметровЗапроса(ПараметрыЗапроса, НачалоПериода, КонецПериода);
	
	СсылкаНаВнешнийОтчет = КАМИ_РаботаСКонстантамиПовтИсп.ПолучитьЗначениеКонстантыКАМИ("Отчет_КомандировочныеРасходы");

	Если НЕ ЗначениеЗаполнено(СсылкаНаВнешнийОтчет) Тогда

		Возврат Новый ТаблицаЗначений;
		
	КонецЕсли;
		
	Если ТипЗнч(СсылкаНаВнешнийОтчет) = Тип("СправочникСсылка.ДополнительныеОтчетыИОбработки") 
		И ЗначениеЗаполнено(СсылкаНаВнешнийОтчет) Тогда

		АдресВоВременномХранилище = ПоместитьВоВременноеХранилище(СсылкаНаВнешнийОтчет.ХранилищеОбработки.Получить());
		
		Попытка
			
			ОписаниеЗащиты = Новый ОписаниеЗащитыОтОпасныхДействий;
			ОписаниеЗащиты.ПредупреждатьОбОпасныхДействиях = Ложь;
			
			ИмяОбработки = ВнешниеОтчеты.Подключить(АдресВоВременномХранилище, , "КАМИ_Exchange", ОписаниеЗащиты);

			ОтчетКомандировочныеРасходы = ВнешниеОтчеты.Создать(ИмяОбработки);
		Исключение
			Возврат Новый ТаблицаЗначений;
		КонецПопытки;
	Иначе
		Возврат Новый ТаблицаЗначений;
	КонецЕсли;
	
	СхемаКомпоновкиДанных = ОтчетКомандировочныеРасходы.ПолучитьМакет("ОсновнаяСхемаКомпоновкиДанных");
	КомпоновщикНастроек = Новый КомпоновщикНастроекКомпоновкиДанных;
	КомпоновщикНастроек.Инициализировать(Новый ИсточникДоступныхНастроекКомпоновкиДанных(СхемаКомпоновкиДанных));
		
	МакетНастройкиКАМИ_КомандировочныеРасходы = ПолучитьМакет("НастройкиКАМИ_КомандировочныеРасходы");
	
	Чтение = Новый ЧтениеXML;
	НовыйСXDTO = Новый СериализаторXDTO(ФабрикаXDTO);
	Чтение.УстановитьСтроку(ПолучитьСтрокуИзДвоичныхДанных(МакетНастройкиКАМИ_КомандировочныеРасходы));
	НастройкиВыгрузки = НовыйСXDTO.ПрочитатьXML(Чтение);
			
	КомпоновщикНастроек.ЗагрузитьНастройки(НастройкиВыгрузки);

	Настройки = КомпоновщикНастроек.ПолучитьНастройки();
	Если СписокОрганизаций.Количество() Тогда
		ЭлементОтбора = Настройки.Отбор.Элементы.Добавить(Тип("ЭлементОтбораКомпоновкиДанных"));
		ЭлементОтбора.ЛевоеЗначение		= Новый ПолеКомпоновкиДанных("Организация");
		ЭлементОтбора.ВидСравнения		= ВидСравненияКомпоновкиДанных.ВСписке;
		ЭлементОтбора.ПравоеЗначение	= СписокОрганизаций;
		ЭлементОтбора.Использование		= Истина;     
		//+ КАМИ 12.09.2024 11:21:37 Гросу Р.И. № Исключить ГК КАМИ
	Иначе
		ЭлементОтбора = Настройки.Отбор.Элементы.Добавить(Тип("ЭлементОтбораКомпоновкиДанных"));
		ЭлементОтбора.ЛевоеЗначение		= Новый ПолеКомпоновкиДанных("Организация");
		//+ КАМИ 05.12.2024 17:57:15 Гросу Р.И. № 0000051314    
		ИсключенныеОрганизации = Новый Массив;
		ИсключенныеОрганизации.Добавить(Справочники.Организации.УправленческаяОрганизация);
		ИсключенныеОрганизации.Добавить(Справочники.Организации.ПолучитьСсылку(Новый УникальныйИдентификатор("10204792-9239-11e7-8e8f-00505683001c"))); //ТЕХНОСЕРВИС 		
		ИсключенныеОрганизации.Добавить(Справочники.Организации.ПолучитьСсылку(Новый УникальныйИдентификатор("d76ecdf5-5f58-11ed-aa1d-00505691f4e4"))); //КАМИ-БЕЛ 
		ИсключенныеОрганизации.Добавить(Справочники.Организации.ПолучитьСсылку(Новый УникальныйИдентификатор("b35191d6-4bb9-11ed-aa13-00505691f4e4"))); //КАМИ-АЛМАТЫ 
		ЭлементОтбора.ВидСравнения		= ВидСравненияКомпоновкиДанных.НеВСписке;
		ЭлементОтбора.ПравоеЗначение	= ИсключенныеОрганизации;
		//ЭлементОтбора.ПравоеЗначение	= Справочники.Организации.УправленческаяОрганизация; 
		//- КАМИ 05.12.2024 17:57:31 Гросу Р.И. 
		ЭлементОтбора.Использование		= Истина;	
		//- КАМИ 12.09.2024 11:21:39 Гросу Р.И. 
	КонецЕсли;  
		
	Если СписокСотрудников.Количество() Тогда
		ЭлементОтбора = Настройки.Отбор.Элементы.Добавить(Тип("ЭлементОтбораКомпоновкиДанных"));
		ЭлементОтбора.ЛевоеЗначение		= Новый ПолеКомпоновкиДанных("ПодотчетноеЛицо");
		ЭлементОтбора.ВидСравнения		= ВидСравненияКомпоновкиДанных.ВСписке;
		ЭлементОтбора.ПравоеЗначение	= СписокСотрудников;
		ЭлементОтбора.Использование		= Истина;  
	КонецЕсли;
	
	Если СписокКомандировок.Количество() Тогда     
		ЭлементОтбора = Настройки.Отбор.Элементы.Добавить(Тип("ЭлементОтбораКомпоновкиДанных"));
		ЭлементОтбора.ЛевоеЗначение		= Новый ПолеКомпоновкиДанных("ЗаявкаНаКомандировку");
		ЭлементОтбора.ВидСравнения		= ВидСравненияКомпоновкиДанных.ВСписке;
		ЭлементОтбора.ПравоеЗначение	= СписокКомандировок;
		ЭлементОтбора.Использование		= Истина;
	КонецЕсли;

	Если СписокСервисныхРабот.Количество() Тогда     
		ЭлементОтбора = Настройки.Отбор.Элементы.Добавить(Тип("ЭлементОтбораКомпоновкиДанных"));
		ЭлементОтбора.ЛевоеЗначение		= Новый ПолеКомпоновкиДанных("ЗаявкаНаКомандировку.КАМИ_ДокументОснование");
		ЭлементОтбора.ВидСравнения		= ВидСравненияКомпоновкиДанных.ВСписке;
		ЭлементОтбора.ПравоеЗначение	= СписокСервисныхРабот;
		ЭлементОтбора.Использование		= Истина;
	КонецЕсли;
	
	ПараметрНачалоПериода = Настройки.ПараметрыДанных.Элементы.Найти("НачалоПериода");
	Если НЕ ПараметрНачалоПериода = Неопределено Тогда
		ПараметрНачалоПериода.Значение = НачалоПериода;
		ПараметрНачалоПериода.Использование = Истина;
	КонецЕсли;
	
	ПараметрКонецПериода = Настройки.ПараметрыДанных.Элементы.Найти("КонецПериода");
	Если НЕ ПараметрКонецПериода = Неопределено Тогда
		ПараметрКонецПериода.Значение = КонецПериода;
		ПараметрКонецПериода.Использование = Истина;
	КонецЕсли;
	
	КомпоновщикМакета = Новый КомпоновщикМакетаКомпоновкиДанных;
	МакетКомпоновки   = КомпоновщикМакета.Выполнить(СхемаКомпоновкиДанных, Настройки, , , Тип("ГенераторМакетаКомпоновкиДанныхДляКоллекцииЗначений"));
	
	ПроцессорКомпоновки = Новый ПроцессорКомпоновкиДанных;
	ПроцессорКомпоновки.Инициализировать(МакетКомпоновки);

	ПроцессорВывода = Новый ПроцессорВыводаРезультатаКомпоновкиДанныхВКоллекциюЗначений;
	ТаблицаРезультата = Новый ТаблицаЗначений;
	
	ПроцессорВывода.УстановитьОбъект(ТаблицаРезультата);
	ПроцессорВывода.Вывести(ПроцессорКомпоновки);
	
	МассивПустыхСтрок = Новый Массив;
	Для Каждого Строчка Из ТаблицаРезультата Цикл
		Если НЕ ЗначениеЗаполнено(Строчка.СуммаНачальныйОстаток)
			И НЕ ЗначениеЗаполнено(Строчка.СуммаПриход)
			И НЕ ЗначениеЗаполнено(Строчка.СуммаРасход)
			И НЕ ЗначениеЗаполнено(Строчка.СуммаКонечныйОстаток) Тогда
			МассивПустыхСтрок.Добавить(Строчка);
		КонецЕсли;	
	КонецЦикла;
	
	Для Каждого Строчка Из МассивПустыхСтрок Цикл
		ТаблицаРезультата.Удалить(Строчка);
	КонецЦикла;
	
	Возврат ТаблицаРезультата;
	
КонецФункции
