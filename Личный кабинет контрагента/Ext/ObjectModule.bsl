		НачалоПериода =  XMLЗначение(Тип("Дата"), ПараметрыЗапроса.Дата); 
	Иначе
		НачалоПериода = ТекущаяДата();
	КонецЕсли;
	
	Если НачалоПериода = Дата(1,1,1) Тогда
		НачалоПериода = ТекущаяДата();
	КонецЕсли;
	
	Если ОбщегоНазначенияКлиентСервер.ЕстьРеквизитИлиСвойствоОбъекта(ПараметрыЗапроса, "КонецПериода") Тогда 
		КонецПериода =  XMLЗначение(Тип("Дата"), ПараметрыЗапроса.КонецПериода);
	ИначеЕсли ОбщегоНазначенияКлиентСервер.ЕстьРеквизитИлиСвойствоОбъекта(ПараметрыЗапроса, "Дата") Тогда 
		КонецПериода =  XMLЗначение(Тип("Дата"), ПараметрыЗапроса.Дата); 
	Иначе
		КонецПериода = ТекущаяДата();
	КонецЕсли;
	
	Если КонецПериода = Дата(1,1,1) Тогда
		КонецПериода = ТекущаяДата();
	КонецЕсли;
	
	ПолучатьДвоичныеДанные = ОбщегоНазначенияКлиентСервер.ЕстьРеквизитИлиСвойствоОбъекта(ПараметрыЗапроса, "ПолучитьФайлы");
	
	мОбъектЗапроса = Новый Запрос; 
	мОбъектЗапроса.Текст = ТекстЗапросаФайлыСервисныхРабот(); 	
	
	мОбъектЗапроса.УстановитьПараметр("СписокДокументов", СписокДокументов);
	мОбъектЗапроса.УстановитьПараметр("СписокФайлов", СписокФайлов);
	мОбъектЗапроса.УстановитьПараметр("НачалоПериода", НачалоПериода);
	мОбъектЗапроса.УстановитьПараметр("КонецПериода", КонецПериода);
	мОбъектЗапроса.УстановитьПараметр("ОтборПоСсылкам", ?(СписокДокументов.Количество(), Истина, Ложь)); 
	мОбъектЗапроса.УстановитьПараметр("ОтборФайлов", ?(СписокФайлов.Количество(), Истина, Ложь));
	
	РезультатЗапроса = мОбъектЗапроса.Выполнить(); 
	
	ТаблицаДокументов = РезультатЗапроса.Выгрузить();
	ТаблицаДокументов.Свернуть("Ссылка");

	ТаблицаРезультата = ПолучитьМассивОписанийФайлов(ТаблицаДокументов.ВыгрузитьКолонку("Ссылка"), Истина, ПолучатьДвоичныеДанные);
	
	Если ОбщегоНазначенияКлиентСервер.ЕстьРеквизитИлиСвойствоОбъекта(ПараметрыЗапроса, "СписокФайлов") Тогда
    	ТаблицаРезультата = ОбщегоНазначенияУТ.МассивВТаблицуЗначений(ТаблицаРезультата);
	КонецЕсли;
	
	Возврат ТаблицаРезультата;
	
КонецФункции
