Функция ПолучитьТаблицуПаспортовНоменклатуры(ПараметрыЗапроса) Экспорт
	
	СписокНоменклатуры = Новый Массив;
   	СписокПаспортов = Новый Массив;
	
	Если ОбщегоНазначенияКлиентСервер.ЕстьРеквизитИлиСвойствоОбъекта(ПараметрыЗапроса, "СписокНоменклатуры") Тогда
		Для Каждого ДанныеНоменклатуры Из ПараметрыЗапроса.СписокНоменклатуры Цикл
			ГУИДНоменклатуры = ДанныеНоменклатуры.GUID;                                                  
			СтруктураПоиска = Неопределено;
			Если ОбщегоНазначенияКлиентСервер.ЕстьРеквизитИлиСвойствоОбъекта(ДанныеНоменклатуры, "Артикул") Тогда
				СтруктураПоиска = Новый Структура("Артикул", ДанныеНоменклатуры.Артикул);
			КонецЕсли;
			Если ОбщегоНазначенияКлиентСервер.ЕстьРеквизитИлиСвойствоОбъекта(ДанныеНоменклатуры, "Код") Тогда
				Если СтруктураПоиска = Неопределено Тогда
					СтруктураПоиска = Новый Структура("Код", ДанныеНоменклатуры.Код);
				Иначе
					СтруктураПоиска.Вставить("Код", ДанныеНоменклатуры.Код);
				КонецЕсли;
			КонецЕсли;
			НоменклатураОбъект = ПолучитьОбъектОбработкиСправочник("Номенклатура", ГУИДНоменклатуры, СтруктураПоиска, Ложь);
			Если НЕ НоменклатураОбъект.ЭтоНовый() Тогда
				СписокНоменклатуры.Добавить(НоменклатураОбъект.Ссылка);
			КонецЕсли;
		КонецЦикла;
	КонецЕсли;
	
	Если ОбщегоНазначенияКлиентСервер.ЕстьРеквизитИлиСвойствоОбъекта(ПараметрыЗапроса, "СписокСсылок") Тогда
		Для Каждого ДанныеСсылки Из ПараметрыЗапроса.СписокСсылок Цикл		
			СписокПаспортов.Добавить(ДанныеСсылки);
		КонецЦикла;
	КонецЕсли;

	Если СписокНоменклатуры.Количество() = 0 И СписокПаспортов.Количество() = 0 Тогда		
		ДанныеОтвета = новый Структура;
		ДанныеОтвета.Вставить("ТекстОшибки","Не найдена ни один паспорт номенклатуры");    
		ДанныеОтвета.Вставить("ПараметрыЗапроса",ПараметрыЗапроса);
		ДанныеОтвета.Вставить("СтатусОтвета",400);
		Возврат ДанныеОтвета; 
	КонецЕсли;  
	
	мОбъектЗапроса = Новый Запрос;
	мОбъектЗапроса.Текст = ТекстЗапросаПаспортовНоменклатуры();	
	
	мОбъектЗапроса.УстановитьПараметр("СписокНоменклатуры", СписокНоменклатуры);
	мОбъектЗапроса.УстановитьПараметр("СписокПаспортов", СписокПаспортов);
	
	РезультатыЗапроса = мОбъектЗапроса.ВыполнитьПакет(); 

	ТаблицаРезультата = ДополнитьРезультатТабличнымиЧастями(РезультатыЗапроса, 2, Новый Структура("ОбластьДействия, Файлы", 3, 4), "Паспорт");
	
	Возврат ТаблицаРезультата;
	
