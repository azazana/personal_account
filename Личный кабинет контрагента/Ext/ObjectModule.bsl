				Если СтруктураПоиска = Неопределено Тогда
					СтруктураПоиска = Новый Структура("Номер", ДанныеДокумента.Номер);
				Иначе
					СтруктураПоиска.Вставить("Номер", ДанныеДокумента.Номер);
				КонецЕсли;
			КонецЕсли;
			ДокументСсылка = ПолучитьСсылкуДокумента(НаименованиеДокумента, ГУИДДокумента, СтруктураПоиска, Ложь);
