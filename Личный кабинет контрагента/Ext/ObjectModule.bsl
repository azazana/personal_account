Функция ПолучитьТаблицуОтчетПоПервойГруппе(ПараметрыЗапроса) Экспорт
		
	ДатаОтчета = ТекущаяДата();

	ИспользоватьДатуОтчета = Ложь;
	Если ОбщегоНазначенияКлиентСервер.ЕстьРеквизитИлиСвойствоОбъекта(ПараметрыЗапроса, "ДатаОтчета") Тогда 
		ДатаОтчета =  XMLЗначение(Тип("Дата"), ПараметрыЗапроса.ДатаОтчета); 
		ИспользоватьДатуОтчета = Истина;
	ИначеЕсли ОбщегоНазначенияКлиентСервер.ЕстьРеквизитИлиСвойствоОбъекта(ПараметрыЗапроса, "Дата") Тогда 
		ДатаОтчета =  XMLЗначение(Тип("Дата"), ПараметрыЗапроса.Дата);   
		ИспользоватьДатуОтчета = Истина;
	Иначе
		ДатаОтчета = ТекущаяДата();
	КонецЕсли;
	
	Если ДатаОтчета = Дата(1,1,1) Тогда
		ДатаОтчета = ТекущаяДата();
	КонецЕсли;
	
	СписокНоменклатуры = ПолучитьСписокСсылокСправочникаИзПараметровЗапроса(ПараметрыЗапроса, "СписокНоменклатуры", "Номенклатура");
	
	СсылкаНаВнешнийОтчет = КАМИ_РаботаСКонстантамиПовтИсп.ПолучитьЗначениеКонстантыКАМИ("Отчет_ПерваяГруппа");

	Если НЕ ЗначениеЗаполнено(СсылкаНаВнешнийОтчет) Тогда

		Возврат Новый ТаблицаЗначений;
		
	КонецЕсли;
		
	Если ТипЗнч(СсылкаНаВнешнийОтчет) = Тип("СправочникСсылка.ДополнительныеОтчетыИОбработки") 
		И ЗначениеЗаполнено(СсылкаНаВнешнийОтчет) Тогда

		АдресВоВременномХранилище = ПоместитьВоВременноеХранилище(СсылкаНаВнешнийОтчет.ХранилищеОбработки.Получить());
		
		Попытка
			
			ОписаниеЗащиты = Новый ОписаниеЗащитыОтОпасныхДействий;
			ОписаниеЗащиты.ПредупреждатьОбОпасныхДействиях = Ложь;
			
			ИмяОбработки = ВнешниеОтчеты.Подключить(АдресВоВременномХранилище, , "КАМИ_Exchange", ОписаниеЗащиты);

			ОтчетПерваяГруппа= ВнешниеОтчеты.Создать(ИмяОбработки);
		Исключение
			Возврат Новый ТаблицаЗначений;
		КонецПопытки;
	Иначе
		Возврат Новый ТаблицаЗначений;
	КонецЕсли;
			
	СхемаКомпоновкиДанных = ОтчетПерваяГруппа.ПолучитьМакет("ОсновнаяСхемаКомпоновкиДанных");
	КомпоновщикНастроек = Новый КомпоновщикНастроекКомпоновкиДанных;
	КомпоновщикНастроек.Инициализировать(Новый ИсточникДоступныхНастроекКомпоновкиДанных(СхемаКомпоновкиДанных));
	
	МакетНастройкиОтчетПоПеровйГруппе = ПолучитьМакет("НастройкиОтчетПерваяГруппаОборудованиеТаблица");
 
	Чтение = Новый ЧтениеXML;
	НовыйСXDTO = Новый СериализаторXDTO(ФабрикаXDTO);
	Чтение.УстановитьСтроку(ПолучитьСтрокуИзДвоичныхДанных(МакетНастройкиОтчетПоПеровйГруппе));
	НастройкиВыгрузки = НовыйСXDTO.ПрочитатьXML(Чтение);
			
	КомпоновщикНастроек.ЗагрузитьНастройки(НастройкиВыгрузки);

	НастройкиОтчета = КомпоновщикНастроек.ПолучитьНастройки();
	
	ВнешниеНаборыДанных = Неопределено;

	Если ИспользоватьДатуОтчета = Истина И НЕ ДатаОтчета = Дата(1,1,1) Тогда   
		ПараметрДатаОтчета = Новый СтандартнаяДатаНачала(ДатаОтчета);
		КомпоновкаДанныхКлиентСервер.УстановитьПараметр(НастройкиОтчета, "ПериодОтчета", ПараметрДатаОтчета, Истина);  
		КомпоновкаДанныхКлиентСервер.УстановитьПараметр(НастройкиОтчета, "ДатаСравнения", ПараметрДатаОтчета, Истина);
		КомпоновкаДанныхКлиентСервер.УстановитьПараметр(НастройкиОтчета, "ДатаСебестоимости", ПараметрДатаОтчета, Истина);
	КонецЕсли;
	ПараметрПериодОтчета = КомпоновкаДанныхКлиентСервер.ПолучитьПараметр(НастройкиОтчета, "ПериодОтчета");
	ЗначениеПараметраПериодОтчета = НачалоДня(ПараметрПериодОтчета.Значение);  
	
	ПараметрВидНоменклатуры = Новый СписокЗначений;
	
	Если ОбщегоНазначенияКлиентСервер.ЕстьРеквизитИлиСвойствоОбъекта(ПараметрыЗапроса, "ВидНоменклатуры") Тогда
		Для Каждого ДанныеВида Из ПараметрыЗапроса.ВидНоменклатуры Цикл
			Если ЗначениеЗаполнено(ДанныеВида) Тогда                                                                    
				ВидНоменклатуры = Справочники.ВидыНоменклатуры.НайтиПоНаименованию(ДанныеВида, Истина);
				Если ЗначениеЗаполнено(ВидНоменклатуры) Тогда
					ПараметрВидНоменклатуры.Добавить(ВидНоменклатуры);
				КонецЕсли;
			КонецЕсли;
		КонецЦикла;
	Иначе
		ПараметрВидНоменклатуры.Добавить(Справочники.ВидыНоменклатуры.НайтиПоНаименованию("01_Оборудование", Истина));
		//ПараметрВидНоменклатуры.Добавить(Справочники.ВидыНоменклатуры.НайтиПоНаименованию("02_Инструмент", Истина));
		//ПараметрВидНоменклатуры.Добавить(Справочники.ВидыНоменклатуры.НайтиПоНаименованию("03_Запчасти", Истина));
		//ПараметрВидНоменклатуры.Добавить(Справочники.ВидыНоменклатуры.НайтиПоНаименованию("06_Обработка инструментов", Истина));
		ПараметрВидНоменклатуры.Добавить(Справочники.ВидыНоменклатуры.НайтиПоНаименованию("10_Прочие ПКИ", Истина));	
	КонецЕсли;
	
	КомпоновкаДанныхКлиентСервер.УстановитьПараметр(НастройкиОтчета, "ВидНоменклатуры", ПараметрВидНоменклатуры, Истина);
	Если СписокНоменклатуры.Количество() > 0 Тогда                                                                       
		КомпоновкаДанныхКлиентСервер.ДобавитьОтбор(НастройкиОтчета, "Номенклатура", СписокНоменклатуры,ВидСравненияКомпоновкиДанных.ВСпискеПоИерархии, Истина);
	КонецЕсли;
	
	ОтчетПерваяГруппа.ЗаполнитьКомпоновку(НастройкиОтчета, ВнешниеНаборыДанных, ЗначениеПараметраПериодОтчета);

	КомпоновщикМакета = Новый КомпоновщикМакетаКомпоновкиДанных;
	МакетКомпоновки   = КомпоновщикМакета.Выполнить(СхемаКомпоновкиДанных, НастройкиОтчета, , , Тип("ГенераторМакетаКомпоновкиДанныхДляКоллекцииЗначений"));
	
	ПроцессорКомпоновки = Новый ПроцессорКомпоновкиДанных;
	ПроцессорКомпоновки.Инициализировать(МакетКомпоновки, ВнешниеНаборыДанных);

	ПроцессорВывода = Новый ПроцессорВыводаРезультатаКомпоновкиДанныхВКоллекциюЗначений;
	ТаблицаРезультата = Новый ТаблицаЗначений;
	
	ПроцессорВывода.УстановитьОбъект(ТаблицаРезультата);
	ПроцессорВывода.Вывести(ПроцессорКомпоновки);
	ТаблицаРезультата.Колонки.Добавить("ВидНоменклатуры", Новый ОписаниеТипов("СправочникСсылка.ВидыНоменклатуры"));
	МассивНоменклатуры = ТаблицаРезультата.ВыгрузитьКолонку("Номенклатура");
	ЗначенияВидов = ОбщегоНазначения.ЗначениеРеквизитаОбъектов(МассивНоменклатуры, "ВидНоменклатуры");
	Для Каждого Строчка Из ТаблицаРезультата Цикл
		Строчка.ВидНоменклатуры = ЗначенияВидов.Получить(Строчка.Номенклатура);
	КонецЦикла;
	
	Возврат ТаблицаРезультата;

КонецФункции
