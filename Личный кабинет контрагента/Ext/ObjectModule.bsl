		НачалоПериода = ТекущаяДата();
	КонецЕсли;
	
	Если ОбщегоНазначенияКлиентСервер.ЕстьРеквизитИлиСвойствоОбъекта(ПараметрыЗапроса, "КонецПериода") Тогда 
		КонецПериода =  XMLЗначение(Тип("Дата"), ПараметрыЗапроса.КонецПериода);
