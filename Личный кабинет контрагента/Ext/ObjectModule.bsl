Функция СоздатьЗаявкуНаРасходДС(тЗаявкаНаКомандировку, СуммаЗаявки = неопределено)
	
	докЗаявкаНаРасходДС = Документы.ЗаявкаНаРасходованиеДенежныхСредств.СоздатьДокумент();
	
	докЗаявкаНаРасходДС.Заполнить(тЗаявкаНаКомандировку);
	
	Если НЕ ЗначениеЗаполнено(докЗаявкаНаРасходДС.Дата) Тогда
		докЗаявкаНаРасходДС.Дата = текущаяДата();	
	конецесли;	
	
	докЗаявкаНаРасходДС.ЖелательнаяДатаПлатежа = докЗаявкаНаРасходДС.Дата + 86400;
	докЗаявкаНаРасходДС.ДатаАвансовогоОтчета = докЗаявкаНаРасходДС.Дата + 7*86400;	
	
	Для каждого строкаОплат из докЗаявкаНаРасходДС.РасшифровкаПлатежа Цикл
		строкаОплат.СтатьяДвиженияДенежныхСредств = справочники.СтатьиДвиженияДенежныхСредств.НайтиПоКоду("812111");	
	конецЦикла;	    
	
	Если НЕ ЗначениеЗаполнено(докЗаявкаНаРасходДС.БанковскийСчетКонтрагента) Тогда
		докЗаявкаНаРасходДС.БанковскийСчетКонтрагента =	ПолучитьБанковскийСчетПоУмолчанию_2(докЗаявкаНаРасходДС.ПодотчетноеЛицо, докЗаявкаНаРасходДС.Валюта);
	КонецЕсли;	
	
	докЗаявкаНаРасходДС.ФормаОплатыНаличная = Ложь;
	докЗаявкаНаРасходДС.ФормаОплатыПлатежнаяКарта = Ложь;
	докЗаявкаНаРасходДС.ФормаОплатыБезналичная = Истина;
	докЗаявкаНаРасходДС.ФормаОплатыЗаявки = Перечисления.ФормыОплаты.Безналичная;	
	
	Если НЕ СуммаЗаявки = неопределено Тогда
		
		докЗаявкаНаРасходДС.СуммаДокумента = СуммаЗаявки; 
		
		Если докЗаявкаНаРасходДС.РасшифровкаПлатежа.Количество() > 0 Тогда
			докЗаявкаНаРасходДС.РасшифровкаПлатежа[0].Сумма = СуммаЗаявки;
			докЗаявкаНаРасходДС.РасшифровкаПлатежа[0].СуммаВзаиморасчетов = СуммаЗаявки;  
		Иначе
			новСтрока = докЗаявкаНаРасходДС.РасшифровкаПлатежа.Добавить();
			новСтрока.Сумма = СуммаЗаявки;
			новСтрока.СуммаВзаиморасчетов = СуммаЗаявки;
			новСтрока.ВалютаВзаиморасчетов = тЗаявкаНаКомандировку.Валюта;
			новСтрока.СтатьяДвиженияДенежныхСредств = справочники.СтатьиДвиженияДенежныхСредств.НайтиПоНаименованию("812111_Оплата командировочных расходов");
			новСтрока.КурсЗнаменательВзаиморасчетов = 1;
			новСтрока.КурсЧислительВзаиморасчетов = 1;
			Если тЗаявкаНаКомандировку.ВыдачаПодОтчет.количество() >0 Тогда
				новСтрока.НаправлениеДеятельности = тЗаявкаНаКомандировку.ВыдачаПодОтчет[0].КАМИ_НаправлениеДеятельности;
			Иначе
				новСтрока.НаправлениеДеятельности =	докЗаявкаНаРасходДС.НаправлениеДеятельности
			КонецЕсли;	
		КонецЕсли; 
		
	КонецЕсли;
	
	новСтрока = докЗаявкаНаРасходДС.РаспределениеПоСчетам.добавить();
	новСтрока.БанковскийСчетКасса =  КАМИ_ПолучитьБанковскийСчетОрганизацииДляЗаявки(докЗаявкаНаРасходДС.Организация, докЗаявкаНаРасходДС.Валюта);			
	
	Если Час(ТекущаяДата()) < 15 ИЛИ (Час(ТекущаяДата()) = 15 И Минута(ТекущаяДата()) = 0) Тогда
		докЗаявкаНаРасходДС.ДатаПлатежа = ТекущаяДата();
		новСтрока.ДатаПлатежа = ТекущаяДата();
	Иначе 
		докЗаявкаНаРасходДС.ДатаПлатежа = ТекущаяДата() + 86400;
		новСтрока.ДатаПлатежа =ТекущаяДата() + 86400;
	КонецЕсли;	
	
	новСтрока.КАМИ_ВалютаРеглУчета = докЗаявкаНаРасходДС.Валюта;
	новСтрока.КАМИ_КурсЧислитель 	= 1;
	новСтрока.КАМИ_КурсЗнаменатель 	= 1;
	
	Если СуммаЗаявки = неопределено Тогда
		новСтрока.КАМИ_СуммаВВалютеРеглУчета = докЗаявкаНаРасходДС.СуммаДокумента;     
		новСтрока.сумма = докЗаявкаНаРасходДС.СуммаДокумента; 
	Иначе
		новСтрока.КАМИ_СуммаВВалютеРеглУчета = СуммаЗаявки;     
		новСтрока.сумма = СуммаЗаявки; 
	КонецЕсли;
	
	докЗаявкаНаРасходДС.Проведен = Истина;
	докЗаявкаНаРасходДС.ДополнительныеСвойства.Вставить("НеОбрабатыватьПроведение", Истина);
	
	докЗаявкаНаРасходДС.Статус = Перечисления.СтатусыЗаявокНаРасходованиеДенежныхСредств.КОплате;
	
	докЗаявкаНаРасходДС.НазначениеПлатежа = "Выдача подотчетных денежных средств. Без Налога (НДС)";
	
	докЗаявкаНаРасходДС.Записать(РежимзаписиДокумента.Запись); 
	
	КАМИ_ОбменДанными.ДобавитьДокументКОтложенномуПроведению(УзелДляОбменаВнешний, докЗаявкаНаРасходДС, докЗаявкаНаРасходДС.ДополнительныеСвойства, 50);
	
	Возврат докЗаявкаНаРасходДС.Ссылка;
	
КонецФункции  

Функция ПолучитьБанковскийСчетПоУмолчанию_2(Получатель, Валюта = Неопределено) Экспорт
	
	Запрос = Новый Запрос("ВЫБРАТЬ
	                      |	КАМИ_ОсновныеСчетаКонтрагентов.Счет КАК БанковскийСчетПолучателя,
	                      |	1 КАК Приоритет
	                      |ПОМЕСТИТЬ втИтог
	                      |ИЗ
	                      |	РегистрСведений.КАМИ_ОсновныеСчетаКонтрагентов КАК КАМИ_ОсновныеСчетаКонтрагентов
	                      |ГДЕ
	                      |	КАМИ_ОсновныеСчетаКонтрагентов.Контрагент = &Получатель
	                      |	И КАМИ_ОсновныеСчетаКонтрагентов.Валюта = &Валюта
	                      |
	                      |ОБЪЕДИНИТЬ ВСЕ
	                      |
	                      |ВЫБРАТЬ
	                      |	БанковскиеСчетаКонтрагентов.Ссылка,
	                      |	2
	                      |ИЗ
	                      |	Справочник.БанковскиеСчетаКонтрагентов КАК БанковскиеСчетаКонтрагентов
	                      |ГДЕ
	                      |	НЕ БанковскиеСчетаКонтрагентов.ПометкаУдаления
	                      |	И НЕ БанковскиеСчетаКонтрагентов.Закрыт
	                      |	И БанковскиеСчетаКонтрагентов.Владелец = &Получатель
	                      |	И (БанковскиеСчетаКонтрагентов.ВалютаДенежныхСредств = &Валюта
	                      |			ИЛИ &Валюта = НЕОПРЕДЕЛЕНО)
	                      |;
	                      |
	                      |////////////////////////////////////////////////////////////////////////////////
	                      |ВЫБРАТЬ
	                      |	втИтог.БанковскийСчетПолучателя КАК БанковскийСчетПолучателя
	                      |ИЗ
	                      |	втИтог КАК втИтог
	                      |
	                      |УПОРЯДОЧИТЬ ПО
	                      |	втИтог.Приоритет");
	
	Запрос.УстановитьПараметр("Получатель", Получатель);
	Запрос.УстановитьПараметр("Валюта", ?(ЗначениеЗаполнено(Валюта), Валюта, Неопределено));
	
	Выборка = Запрос.Выполнить().Выбрать();
	Если Выборка.Следующий() Тогда
		БанковскийСчетПолучателя = Выборка.БанковскийСчетПолучателя;
	Иначе
		БанковскийСчетПолучателя = Справочники.БанковскиеСчетаКонтрагентов.ПустаяСсылка();
	КонецЕсли;
	
	Возврат БанковскийСчетПолучателя;

КонецФункции

&НаСервере
Функция КАМИ_ПолучитьБанковскийСчетОрганизацииДляЗаявки(Организация, Валюта) 
	
		Запрос = Новый Запрос;		
		Запрос.Текст = 
			"ВЫБРАТЬ РАЗРЕШЕННЫЕ
			|	БанковскиеСчетаОрганизаций.РасчетныйСчет КАК РасчетныйСчет
			|ИЗ
			|	РегистрСведений.КАМИ_СоответствиеНаправленияДеятельностиИРасчетногоСчета КАК БанковскиеСчетаОрганизаций
			|ГДЕ
			|	НЕ БанковскиеСчетаОрганизаций.РасчетныйСчет.Закрыт
			|	И БанковскиеСчетаОрганизаций.Организация = &Организация    
			|   И БанковскиеСчетаОрганизаций.ИспользоватьДляЗаявокНаРасходДС
			|	И БанковскиеСчетаОрганизаций.РасчетныйСчет.ВалютаДенежныхСредств = &Валюта";
		
		Запрос.УстановитьПараметр("Организация", Организация); 
		Запрос.УстановитьПараметр("Валюта", Валюта);
		РезультатЗапроса = Запрос.Выполнить();
		
		ВыборкаДетальныеЗаписи = РезультатЗапроса.Выбрать();
		
		Если ВыборкаДетальныеЗаписи.Количество() = 1 И ВыборкаДетальныеЗаписи.Следующий() Тогда
			БанковскийСчетОрганизации = ВыборкаДетальныеЗаписи.РасчетныйСчет; 
		Иначе
			БанковскийСчетОрганизации = Справочники.БанковскиеСчетаОрганизаций.ПустаяСсылка();
		КонецЕсли;
			
	Возврат БанковскийСчетОрганизации; 

КонецФункции

