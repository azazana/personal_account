Функция ОчередьПолучитьСервисныеРаботыПоКомандировкам(ПараметрыЗапроса) Экспорт 
	
	СписокСервисныхРабот = Новый Массив;
	СписокКомандировок = ПараметрыЗапроса.СписокСсылок;
	Для сч = 0 по СписокКомандировок.количество() -1 Цикл
		СписокСервисныхРабот.Добавить(СписокКомандировок[сч].КАМИ_ДокументОснование);	
	КонецЦикла;
	
	//ЗаписьЖурналаРегистрации.
	
	ПараметрыЗапроса.удалить("СписокСсылок");
	ПараметрыЗапроса.вставить("СписокСсылок", СписокСервисныхРабот);

	УзелДляОбмена = ПланыОбмена.КАМИ_ОбменСервиснаяСлужба.НайтиПоНаименованию("Сервисная служба");
	ПланыОбмена.УдалитьРегистрациюИзменений(УзелДляОбмена, СписокКомандировок);
	ПланыОбмена.ЗарегистрироватьИзменения(УзелДляОбмена, СписокСервисныхРабот);
	
	Возврат ПолучитьРезультатФормированияОчередиСообщений(ПараметрыЗапроса, "ПолучитьСервисныеРаботы");
	
