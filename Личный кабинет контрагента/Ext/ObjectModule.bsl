//+ КАМИ 27.09.2024 17:56:52 Гросу Р.И. № 0000036647
Процедура ЗаполнитьСтоимостьРаботСервисныеРаботы(СсылкаОбъект, ЕстьКомандировка)
	Если СсылкаОбъект.ВидРабот = Справочники.КАМИ_ВидыРабот.Рекламация Тогда
		
		Если СсылкаОбъект.РезультатРаботы = Перечисления.КАМИ_РезультатРаботы.ЗавершеноУдаленно Тогда
			
			СсылкаОбъект.СтоимостьРабот    = КАМИ_РаботаСКонстантамиПовтИсп.ПолучитьЗначениеКонстантыКАМИ("СервисныеРаботы Стоимость работ"); // 4500; // с 01.10.2023, КАМИ 348514	

			СсылкаОбъект.ДниНаПроизводстве = 0;
			СсылкаОбъект.ДниВДороге        = 0;
			
			//Очистим КомандировочныеРасходы
			Для Каждого СтрокаКР ИЗ СсылкаОбъект.КомандировочныеРасходы Цикл
				СтрокаКР.Цена       = 0;
				СтрокаКР.Сумма      = 0;
				СтрокаКР.Количество = 0;	
			КонецЦикла;
		Иначе
			СсылкаОбъект.СтоимостьРабот    = 0;
		КонецЕсли;
		
		Если  СсылкаОбъект.ДниНаПроизводстве > 0 ИЛИ СсылкаОбъект.ДниВДороге > 0 Тогда
			
			Если ЗначениеЗаполнено(СсылкаОбъект.Проект) И ЗначениеЗаполнено(СсылкаОбъект.Подразделение) И ЗначениеЗаполнено(СсылкаОбъект.НаправлениеДеятельности) Тогда
				
				ПодразделениеСервис = КАМИ_РаботаСКонстантамиПовтИсп.ПолучитьЗначениеКонстантыКАМИ("ЦФО в Сервисных работах");
				Если СсылкаОбъект.Подразделение = ПодразделениеСервис Тогда 		
					Отбор = Новый Структура("Проект, Подразделение, НаправлениеДеятельности", СсылкаОбъект.Проект, СсылкаОбъект.Подразделение, СсылкаОбъект.НаправлениеДеятельности);
				Иначе
					Отбор = Новый Структура("Проект, Подразделение", СсылкаОбъект.Проект, СсылкаОбъект.Подразделение);
				КонецЕсли;	
					
				РегДанные = РегистрыСведений.КАМИ_НормыЗатратНаСервисныеРаботы.СрезПоследних(СсылкаОбъект.Дата, Отбор);
				
				Если РегДанные.Количество() > 0 Тогда
					
					СсылкаОбъект.СтоимостьРабот = (СсылкаОбъект.ДниНаПроизводстве + СсылкаОбъект.ДниВДороге) * РегДанные[0].СтандартныеЗатратыПоГарантии;
					
					
					Если ЕстьКомандировка Тогда
						СтатьяСуточные = КАМИ_РаботаСКонстантамиПовтИсп.ПолучитьЗначениеКонстантыКАМИ("Статья расходов 1 (Сервис)");
						СтруктураДляПоиска = Новый Структура;
						СтруктураДляПоиска.Вставить("СтатьяЗатрат",СтатьяСуточные);
						МассивСтрок = СсылкаОбъект.КомандировочныеРасходы.НайтиСтроки(СтруктураДляПоиска);  
						Если МассивСтрок.Количество() > 0 Тогда
							Для Каждого СтрокаТЧ ИЗ МассивСтрок Цикл
								СтрокаТЧ.Цена       = РегДанные[0].Суточные;
								СтрокаТЧ.Сумма      = (СсылкаОбъект.ДниНаПроизводстве + СсылкаОбъект.ДниВДороге) * РегДанные[0].Суточные;
								СтрокаТЧ.Количество = (СсылкаОбъект.ДниНаПроизводстве + СсылкаОбъект.ДниВДороге);
							КонецЦикла;	
						КонецЕсли;	
					КонецЕсли;
				КонецЕсли;
			КонецЕсли;
		КонецЕсли;	
	КонецЕсли;
	
КонецПроцедуры
